---
// Static redirect stub for the /blog → /review migration
// (RFC: docs/rfcs/FEAT-blog-to-review-migration.md).
//
// The site is `output: 'static'` (S3 + CloudFront) — there is no server to emit a
// real HTTP 301. This stub instead guarantees old `/blog/*` URLs NEVER 404: every
// old path keeps a built `index.html` that returns HTTP 200 and immediately sends
// the visitor on. It combines, in priority order:
//   1. `location.replace()` — instant client redirect, leaves no history entry.
//   2. `<meta http-equiv="refresh">` — fallback when JS is disabled.
//   3. `<link rel="canonical">` to the new URL — search engines consolidate ranking.
//   4. `robots: noindex, follow` — drop the old URL from the index, follow to the new.
//   5. a visible link — last-resort manual navigation.
//
// A true HTTP 301 (preferred for SEO link-equity) is a documented follow-up: extend
// the existing CloudFront Function `handler` (viewer-request) to 301 `^/blog/` →
// `/review/` (owner-applied — its source is console-managed, not in IaC).
import { SITE } from '@constants'

interface Props {
	/** Destination path, e.g. `/review/some-slug/`. */
	to: string
}
const { to } = Astro.props
const dest = to.startsWith('/') ? to : `/${to}`
// Canonical must be absolute (matches seo.astro; the rel=canonical spec prefers it).
// The redirect itself stays relative so it works regardless of host.
const canonical = new URL(dest, SITE.url).toString()
---
<!doctype html>
<html lang="ko">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>이동되었습니다 · buckit</title>
		<link rel="canonical" href={canonical} />
		<meta name="robots" content="noindex, follow" />
		<meta http-equiv="refresh" content={`0; url=${dest}`} />
		<script is:inline set:html={`location.replace(${JSON.stringify(dest)})`}></script>
		<style>
			body {
				font-family: system-ui, -apple-system, sans-serif;
				max-width: 32rem;
				margin: 18vh auto;
				padding: 0 1.25rem;
				text-align: center;
				line-height: 1.6;
				color: #333;
			}
			a { color: #b5341b; }
		</style>
	</head>
	<body>
		<p>이 페이지는 <a href={dest}>{dest}</a> 로 이동했습니다.</p>
	</body>
</html>
