---
/* frontmatter 없음 */
---

<style>
  .searchbar{
    --bg:#f3f4f6; --bd:#d1d5db; --fg:#111827;
    display:grid;
    grid-template-columns: minmax(280px, 1fr) auto;
    align-items:center;
    gap:.5rem;
    padding:.5rem .75rem;
    border:1px solid var(--bd);
    border-radius:8px;
    background:var(--bg);
    color:var(--fg);
    box-shadow:0 1px 2px rgba(0,0,0,.04);
  }

  .searchForm{ display:flex; align-items:center; gap:.5rem; min-width:280px; }

  .input{
    width:100%;
    background:#fff;
    border:1px solid #d1d5db;
    border-radius:8px;
    font-size:1rem;
    padding:.5rem .75rem;
    outline:none;
  }
  .input::placeholder{ color:#6b7280; }

  .section-title{ font-weight:800; margin:1rem 0 .5rem; }

  .actions{ display:flex; align-items:center; gap:.25rem; }

  .icon-btn{
    border:none; background:transparent; padding:.4rem; border-radius:8px;
    display:flex; align-items:center; justify-content:center;
    transition: background .15s ease, transform .1s ease;
  }
  .icon-btn:hover{ cursor:pointer; background:rgba(0,0,0,.06); transform:scale(1.05); }

  .status-line{ margin-top:.5rem; font-size:.85rem; color:#6b7280; }

  .results-wrap{
    margin-top:.75rem;
    border:1px solid #e5e7eb;
    border-radius:10px;
    background:#fff;
    overflow-x:auto;
    padding:.75rem;
  }

  .results-grid{
    display:flex;
    flex-direction:column;
    gap:1rem;
  }

  .results-col{
    display:flex;
    flex-direction:column;
    gap:.5rem;
    min-width:0;
  }

  .results-heading{ font-weight:800; }

  .results-row{
    --card-px:135px;
    display:flex;
    gap:1.25rem;
    overflow-x:auto;
    padding-bottom:.5rem;
  }

  :global(.card){
    flex:0 0 var(--card-px);
    display:flex;
    flex-direction:column;
    gap:.6rem;
    border-radius:14px;
    cursor:pointer;
  }

  :global(.art){
    width:100%;
    aspect-ratio:1/1;
    border-radius:14px;
    overflow:hidden;
    background:#f3f4f6;
    box-shadow:0 2px 10px rgba(0,0,0,.06);
    border:1px solid #e5e7eb;
    transition:box-shadow .15s, transform .06s, border-color .15s;
  }

  :global(.card:hover .art){
    transform:translateY(-2px);
    box-shadow:0 8px 24px rgba(0,0,0,.12);
    border-color:#d1d5db;
  }

  :global(.thumb){
    width:100%!important;
    height:100%!important;
    object-fit:cover!important;
    object-position:center!important;
    display:block;
  }

  :global(.meta){ display:flex; flex-direction:column; gap:.25rem; width:100%; }
  :global(.title){
    font-size:1.05rem; font-weight:800; color:#111827; line-height:1.2;
    white-space:normal; overflow:hidden; text-overflow:ellipsis;
  }
  :global(.type){
    font-size:.9rem; color:#6b7280;
    white-space:normal; overflow:hidden; text-overflow:ellipsis;
  }

  :global(.thumb), :global(.meta), :global(.title), :global(.type){ pointer-events:none; }
</style>

<h2 class="section-title">Music Search</h2>

<section id="dbSearchbar" class="searchbar">
  <div class="searchForm">
    <!-- write/index.ts에서 Enter 막는 로직이 searchBar 제외라 id 유지 -->
    <input id="searchBar" class="input" type="search" placeholder="Search artists, albums, tracks (DB first)" />
  </div>

  <div class="actions">
    <!-- DB 검색 -->
    <button class="icon-btn" id="dbSubmitBtn" type="button" title="Search DB" aria-label="Search DB">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" style="width:1.25em; height:1.25em; opacity:0.7;">
        <g stroke-linejoin="round" stroke-linecap="round" stroke-width="2.5" fill="none" stroke="currentColor">
          <circle cx="11" cy="11" r="8"></circle>
          <path d="m21 21-4.3-4.3"></path>
        </g>
      </svg>
    </button>

    <!-- Sync (Spotify candidates + worker enqueue) -->
    <button class="icon-btn" id="dbSyncBtn" type="button" title="Sync (Spotify candidates)" aria-label="Sync">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" style="width:1.25em; height:1.25em; opacity:0.7;">
        <path d="M21 12a9 9 0 1 1-3-6.7" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
        <path d="M21 3v6h-6" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>

    <!-- Spotify 화면에서 DB로 돌아가기 -->
    <button class="icon-btn" id="dbBackBtn" type="button" title="Back to DB" aria-label="Back" hidden>
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" style="width:1.25em; height:1.25em; opacity:0.7;">
        <path d="M15 18l-6-6 6-6" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>
  </div>
</section>

<div class="status-line" id="dbStatus"></div>

<div class="results-wrap" id="resultsWrap" hidden>
  <div class="results-grid" id="resultsGrid">
    <div class="results-col" id="artistsCol">
      <div class="results-heading">Artists</div>
      <div class="results-row" id="artistsRow"></div>
    </div>

    <div class="results-col" id="albumsCol">
      <div class="results-heading">Albums</div>
      <div class="results-row" id="albumsRow"></div>
    </div>

    <div class="results-col" id="tracksCol">
      <div class="results-heading">Tracks</div>
      <div class="results-row" id="tracksRow"></div>
    </div>
  </div>
</div>

<script src="../scripts/searchBarDb.client.ts"></script>