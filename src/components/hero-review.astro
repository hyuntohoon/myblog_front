---
import type { CollectionEntry } from 'astro:content'
import PartialStars from '@components/partial-stars.astro'

export interface Props {
  post: CollectionEntry<'blog'>
}

const { post } = Astro.props
const { title, description, date, category, albumCover, image, musicReview, slug, rating, ratingScale, bestNew } = post.data

const cover = albumCover || image || musicReview?.cover?.src
const artist = musicReview?.artists?.join(', ')
const albumTitle = musicReview?.title
// Canonical rating is top-level (0–5); fall back to legacy nested. Normalize 0–5.
const ratingValue = rating ?? musicReview?.rating?.value ?? null
const ratingScaleEff = rating != null ? ratingScale : musicReview?.rating?.scale ?? 5
const stars = ratingValue == null ? null : ratingScaleEff === 10 ? ratingValue / 2 : ratingValue
const formattedDate = new Date(date).toLocaleDateString('ko-KR', {
  year: 'numeric',
month: 'long',
day: 'numeric',
})
---

<article class="hero">
  <div class="hero-grid">

    <!-- Cover -->
    <div class="hero-cover-wrap">
      <a href={`/blog/${slug}`} class="hero-cover-link" tabindex="-1" aria-hidden="true">
        <div class="hero-cover">
          {bestNew && <span class="hero-bnm">Best New</span>}
          {cover ?
(
            <img src={cover} alt={albumTitle ?? title} loading="eager" class="hero-img" />
          ) :
(
            <div class="hero-placeholder">
              <span>{(albumTitle ?? title).slice(0, 2).toUpperCase()}</span>
            </div>
          )}
        </div>
      </a>
      {artist && albumTitle && (
        <div class="hero-cover-caption">
          <span class="mono-label">{artist}</span>
          <span class="mono-label" style="color: var(--color-faded);">{formattedDate}</span>
        </div>
      )}
    </div>

    <!-- Text -->
    <div class="hero-text">
      {category && (
        <div class="hero-meta">
          <span class="mono-label" style="color: var(--color-accent); letter-spacing: 0.12em;">
            {category.toUpperCase()}
          </span>
          {stars != null && <span class="mono-label" style="color: var(--color-faded);">·</span>}
          {stars != null && (
            <span class="mono-label" style="color: var(--color-faded);">
              Album Review
            </span>
          )}
        </div>
      )}

      <a href={`/blog/${slug}`} class="hero-title-link">
        {artist && (
          <p class="hero-artist">{artist}</p>
        )}
        <h2 class="hero-title">
          <em>{albumTitle ?? title}</em>
        </h2>
      </a>

      {description && (
        <p class="hero-dek">{description}</p>
      )}

      <!-- Score row -->
      {stars != null && (
        <div class="hero-score-row">
          <PartialStars value={stars} size={32} ariaLabel={`별점 ${stars} / 5`} />
          <a href={`/blog/${slug}`} class="hero-cta">리뷰 읽기 →</a>
        </div>
      )}
      {stars == null && (
        <div style="margin-top: 1rem;">
          <a href={`/blog/${slug}`} class="hero-cta">읽기 →</a>
        </div>
      )}
    </div>
  </div>
</article>

<style>
  .hero {
    padding: 56px 0 64px;
    border-bottom: 1px solid var(--color-border);
  }
  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(0, 1fr);
    gap: 56px;
    align-items: start;
  }

  /* Cover */
  .hero-cover-wrap {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .hero-cover-link {
    display: block;
  }
  .hero-cover {
    position: relative;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    border: 1px solid var(--color-border-soft);
    transition: transform 0.5s cubic-bezier(0.2, 0, 0.2, 1);
  }
  .hero-bnm {
    position: absolute;
    top: 0;
    left: 0;
    z-index: 2;
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-on-accent, #fff);
    background: var(--color-accent);
    padding: 5px 9px;
  }
  .hero-cover:hover {
    transform: scale(1.01);
  }
  .hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .hero-placeholder {
    width: 100%;
    height: 100%;
    background: var(--color-paper);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-serif);
    font-size: clamp(48px, 8vw, 96px);
    font-weight: 700;
    font-style: italic;
    color: var(--color-faded);
    letter-spacing: -0.04em;
  }
  .hero-cover-caption {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  /* Text */
  .hero-text {
    padding-top: 32px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .hero-meta {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .hero-title-link {
    display: block;
    text-decoration: none;
    color: inherit;
  }
  .hero-title-link:hover .hero-title {
    color: var(--color-accent);
  }
  .hero-artist {
    font-family: var(--font-mono);
    font-size: 13px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-text);
    margin: 0 0 8px;
  }
  .hero-title {
    margin: 0;
    font-family: var(--font-serif);
    font-size: clamp(40px, 5.5vw, 72px);
    line-height: 0.96;
    letter-spacing: -0.025em;
    font-weight: 500;
    color: var(--color-text);
    transition: color 0.2s;
  }
  .hero-title em {
    font-style: italic;
  }
  .hero-dek {
    font-family: var(--font-serif);
    font-size: 18px;
    line-height: 1.55;
    color: var(--color-subtle);
    max-width: 52ch;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* Score */
  .hero-score-row {
    display: flex;
    align-items: center;
    gap: 20px;
    padding: 20px 0 4px;
    border-top: 1px solid var(--color-border);
    margin-top: 8px;
  }
  .hero-cta {
    font-family: var(--font-mono);
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text);
    border-bottom: 1px solid currentColor;
    padding-bottom: 2px;
    text-decoration: none;
    transition: opacity 0.2s;
  }
  .hero-cta:hover {
    opacity: 0.6;
  }

  /* Mobile */
  @media (max-width: 768px) {
    .hero {
      padding: 32px 0 40px;
    }
    .hero-grid {
      grid-template-columns: 1fr;
      gap: 28px;
    }
    .hero-text {
      padding-top: 0;
    }
    .hero-title {
      font-size: clamp(32px, 8vw, 48px);
    }
  }
</style>
