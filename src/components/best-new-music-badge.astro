---
/**
 * Best New Music 뱃지 — album_classics/high-rating 포스트에 표시
 * 크기: 'sm' (카드용) | 'md' (리뷰 상세 기본)
 */
export interface Props {
  size?: 'sm' | 'md'
}

const { size = 'md' } = Astro.props
---

<span class={`bnm-badge bnm-badge--${size}`} aria-label="Best New Music">
  Best New Music
</span>

<style>
  .bnm-badge {
    display: inline-block;
    font-family: var(--font-mono);
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-bg);
    background: var(--color-accent);
    line-height: 1;
    white-space: nowrap;
  }
  .bnm-badge--sm {
    font-size: 9px;
    padding: 2px 6px;
  }
  .bnm-badge--md {
    font-size: 11px;
    padding: 4px 10px;
  }
</style>
