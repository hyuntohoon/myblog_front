---
import type { CollectionEntry } from 'astro:content'

export interface Props {
  posts: CollectionEntry<'blog'>[]
  title?: string
}

const { posts, title = 'Latest Reviews' } = Astro.props
---

<section class="reviews-section">
  <div class="section-head">
    <div class="rule-label">
      <span class="rule-dot"></span>
      <span>{title}</span>
    </div>
  </div>

  <ul class="review-grid">
    {posts.map((post) => {
      const { title: postTitle, slug, date, category, albumCover, image, musicReview } = post.data
      const cover = albumCover || image || musicReview?.cover?.src
      const artist = musicReview?.artists?.join(', ')
      const albumTitle = musicReview?.title
      const rating = musicReview?.rating?.value
      const ratingScale = musicReview?.rating?.scale ?? 10
      const displayDate = new Date(date).toLocaleDateString('ko-KR', {
        year: 'numeric', month: 'short', day: 'numeric'
      })

      return (
        <li>
          <a href={`/blog/${slug}`} class="review-card">
            <!-- Cover -->
            <div class="rc-cover">
              {cover ? (
                <img
                  src={cover}
                  alt={albumTitle ?? postTitle}
                  loading="lazy"
                  class="rc-img"
                />
              ) : (
                <div class="rc-placeholder">
                  <span>{(albumTitle ?? postTitle).slice(0, 2).toUpperCase()}</span>
                </div>
              )}
              {rating != null && (
                <div class="rc-score-overlay">
                  <span class="rc-score-num">{rating % 1 === 0 ? rating.toFixed(1) : rating}</span>
                </div>
              )}
            </div>

            <!-- Info -->
            <div class="rc-info">
              {artist && <p class="rc-artist">{artist}</p>}
              <p class="rc-title">{albumTitle ?? postTitle}</p>
              <div class="rc-meta">
                {category && <span class="mono-label rc-cat">{category}</span>}
                <span class="mono-label" style="color: var(--color-faded);">{displayDate}</span>
              </div>
            </div>
          </a>
        </li>
      )
    })}
  </ul>
</section>

<style>
  .reviews-section {
    padding: 56px 0;
  }
  .section-head {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 28px;
  }
  .rule-label {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text);
  }
  .rule-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-text);
    flex-shrink: 0;
  }

  /* Grid */
  .review-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px 24px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  /* Card */
  .review-card {
    display: flex;
    flex-direction: column;
    gap: 10px;
    text-decoration: none;
    color: inherit;
  }
  .review-card:hover .rc-cover {
    transform: translateY(-3px);
  }
  .review-card:hover .rc-title {
    color: var(--color-accent);
  }

  /* Cover with score overlay */
  .rc-cover {
    position: relative;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    border: 1px solid var(--color-border-soft);
    transition: transform 0.35s cubic-bezier(0.2, 0, 0.2, 1);
  }
  .rc-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .rc-placeholder {
    width: 100%;
    height: 100%;
    background: var(--color-paper);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-serif);
    font-size: 28px;
    font-style: italic;
    font-weight: 700;
    color: var(--color-faded);
  }
  /* Score badge on hover */
  .rc-score-overlay {
    position: absolute;
    bottom: 8px;
    right: 8px;
    background: rgba(0, 0, 0, 0.78);
    padding: 4px 8px;
    opacity: 0;
    transition: opacity 0.2s;
  }
  .review-card:hover .rc-score-overlay {
    opacity: 1;
  }
  .rc-score-num {
    font-family: var(--font-serif);
    font-size: 18px;
    font-weight: 600;
    color: #f5f3ee;
    letter-spacing: -0.02em;
  }

  /* Info */
  .rc-info {
    display: flex;
    flex-direction: column;
    gap: 3px;
  }
  .rc-artist {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text);
    margin: 0;
  }
  .rc-title {
    font-family: var(--font-serif);
    font-size: 18px;
    line-height: 1.2;
    font-weight: 500;
    color: var(--color-text);
    letter-spacing: -0.01em;
    margin: 0;
    transition: color 0.2s;
  }
  .rc-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: 2px;
  }
  .rc-cat {
    color: var(--color-subtle);
  }
  .rc-cat::after {
    content: '·';
    margin-left: 8px;
    color: var(--color-faded);
  }

  @media (max-width: 1024px) {
    .review-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 640px) {
    .reviews-section {
      padding: 36px 0;
    }
    .review-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 18px 14px;
    }
    .rc-title {
      font-size: 15px;
    }
  }
</style>
