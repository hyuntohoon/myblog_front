---
import type { CollectionEntry } from 'astro:content'
import PartialStars from '@components/partial-stars.astro'

export interface Props {
  posts: CollectionEntry<'blog'>[]
  title?: string
}

const { posts, title = 'Latest Reviews' } = Astro.props
---

<section class="reviews-section">
  <div class="section-head">
    <div class="rule-label">
      <span class="rule-dot"></span>
      <span>{title}</span>
    </div>
  </div>

  <ul class="review-grid">
    {posts.map((post) => {
      const { title: postTitle, slug, date, description, albumCover, image, musicReview, rating, ratingScale, bestNew } = post.data
      const cover = albumCover || image || musicReview?.cover?.src
      const artist = musicReview?.artists?.join(', ')
      const albumTitle = musicReview?.title
      const ratingValue = rating ?? musicReview?.rating?.value ?? null
      const ratingScaleEff = rating != null ? ratingScale : musicReview?.rating?.scale ?? 5
      const stars = ratingValue == null ? null : ratingScaleEff === 10 ? ratingValue / 2 : ratingValue
      const displayDate = new Date(date).toLocaleDateString('ko-KR', {
        year: 'numeric',
month: 'short',
day: 'numeric',
      })

      return (
        <li>
          <a href={`/blog/${slug}`} class="review-card">
            <!-- Cover -->
            <div class="rc-cover">
              {bestNew && <span class="rc-bnm">Best New</span>}
              {cover ?
(
                <img
	src={cover}
	alt={albumTitle ?? postTitle}
	loading="lazy"
	class="rc-img"
                />
              ) :
(
                <div class="rc-placeholder">
                  <span>{(albumTitle ?? postTitle).slice(0, 2).toUpperCase()}</span>
                </div>
              )}
            </div>

            <!-- Info -->
            <div class="rc-info">
              {artist && <p class="rc-artist">{artist}</p>}
              <p class="rc-title">{albumTitle ?? postTitle}</p>
              {description && <p class="rc-excerpt">{description}</p>}
              <div class="rc-foot">
                {stars != null ?
(
                  <PartialStars value={stars} size={15} ariaLabel={`별점 ${stars} / 5`} />
                ) :
(
                  <span></span>
                )}
                <span class="mono-label" style="color: var(--color-faded);">{displayDate}</span>
              </div>
            </div>
          </a>
        </li>
      )
    })}
  </ul>
</section>

<style>
  .reviews-section {
    padding: 56px 0;
  }
  .section-head {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 28px;
  }
  .rule-label {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text);
  }
  .rule-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-text);
    flex-shrink: 0;
  }

  /* Grid */
  .review-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px 24px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  /* Card */
  .review-card {
    display: flex;
    flex-direction: column;
    gap: 10px;
    text-decoration: none;
    color: inherit;
  }
  .review-card:hover .rc-cover {
    transform: translateY(-3px);
  }
  .review-card:hover .rc-title {
    color: var(--color-accent);
  }

  /* Cover */
  .rc-cover {
    position: relative;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    border: 1px solid var(--color-border-soft);
    transition: transform 0.35s cubic-bezier(0.2, 0, 0.2, 1);
  }
  .rc-bnm {
    position: absolute;
    top: 0;
    left: 0;
    z-index: 2;
    font-family: var(--font-mono);
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-on-accent, #fff);
    background: var(--color-accent);
    padding: 4px 7px;
  }
  .rc-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .rc-placeholder {
    width: 100%;
    height: 100%;
    background: var(--color-paper);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-serif);
    font-size: 28px;
    font-style: italic;
    font-weight: 700;
    color: var(--color-faded);
  }

  /* Info */
  .rc-info {
    display: flex;
    flex-direction: column;
    gap: 5px;
  }
  .rc-artist {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text);
    margin: 0;
  }
  .rc-title {
    font-family: var(--font-serif);
    font-size: 18px;
    line-height: 1.2;
    font-weight: 500;
    color: var(--color-text);
    letter-spacing: -0.01em;
    margin: 0;
    transition: color 0.2s;
  }
  .rc-excerpt {
    font-family: var(--font-serif);
    font-size: 14px;
    line-height: 1.5;
    color: var(--color-subtle);
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .rc-foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
    border-top: 1px solid var(--color-border);
    padding-top: 10px;
    margin-top: 4px;
  }

  @media (max-width: 1024px) {
    .review-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 640px) {
    .reviews-section {
      padding: 36px 0;
    }
    .review-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 18px 14px;
    }
    .rc-title {
      font-size: 15px;
    }
  }
</style>
