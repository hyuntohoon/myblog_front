---
import type { CollectionEntry } from 'astro:content'

export interface Props {
  posts: CollectionEntry<'blog'>[]
}

const { posts } = Astro.props

if (posts.length === 0) return
---

<section class="bestnew">
  <!-- Section header -->
  <div class="section-head">
    <div class="rule-label">
      <span class="rule-dot" style="background: var(--color-accent);"></span>
      <span>Best New Music</span>
    </div>
    <a href="/blog/category/review" class="section-link">모두 보기 →</a>
  </div>

  <!-- 4-column grid -->
  <ul class="bestnew-grid">
    {posts.slice(0, 4).map((post) => {
      const { title, slug, date, albumCover, image, musicReview } = post.data
      const cover = albumCover || image || musicReview?.cover?.src
      const artist = musicReview?.artists?.join(', ')
      const albumTitle = musicReview?.title
      const rating = musicReview?.rating?.value
      const ratingScale = musicReview?.rating?.scale ?? 10

      return (
        <li>
          <a href={`/blog/${slug}`} class="bn-card">
            <!-- Cover -->
            <div class="bn-cover">
              {cover ? (
                <img
                  src={cover}
                  alt={albumTitle ?? title}
                  loading="lazy"
                  class="bn-img"
                />
              ) : (
                <div class="bn-placeholder">
                  <span>{(albumTitle ?? title).slice(0, 2).toUpperCase()}</span>
                </div>
              )}
            </div>

            <!-- Meta -->
            <div class="bn-meta">
              {artist && <p class="bn-artist">{artist}</p>}
              <p class="bn-album">{albumTitle ?? title}</p>
              <div class="bn-score">
                {rating != null ? (
                  <>
                    <span class="score-badge">
                      <span class="score-num">{rating % 1 === 0 ? rating.toFixed(1) : rating}</span>
                      <span class="score-denom">/{ratingScale}</span>
                    </span>
                    <span class="bnm-badge">Best New Music</span>
                  </>
                ) : (
                  <span class="mono-label" style="color: var(--color-faded);">
                    {new Date(date).toLocaleDateString('ko-KR', { month: 'short', day: 'numeric' })}
                  </span>
                )}
              </div>
            </div>
          </a>
        </li>
      )
    })}
  </ul>
</section>

<style>
  .bestnew {
    padding: 56px 0;
    border-bottom: 1px solid var(--color-border);
  }
  .section-head {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 28px;
  }
  .rule-label {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text);
  }
  .rule-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .section-link {
    font-family: var(--font-mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-subtle);
    text-decoration: none;
    transition: color 0.2s;
  }
  .section-link:hover {
    color: var(--color-accent);
  }

  /* Grid */
  .bestnew-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 28px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  /* Card */
  .bn-card {
    display: flex;
    flex-direction: column;
    gap: 10px;
    text-decoration: none;
    color: inherit;
  }
  .bn-card:hover .bn-cover {
    transform: translateY(-3px);
  }
  .bn-card:hover .bn-album {
    color: var(--color-accent);
  }
  .bn-cover {
    aspect-ratio: 1 / 1;
    overflow: hidden;
    border: 1px solid var(--color-border-soft);
    transition: transform 0.35s cubic-bezier(0.2, 0, 0.2, 1);
  }
  .bn-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .bn-placeholder {
    width: 100%;
    height: 100%;
    background: var(--color-paper);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-serif);
    font-size: 32px;
    font-style: italic;
    font-weight: 700;
    color: var(--color-faded);
  }
  .bn-meta {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .bn-artist {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text);
    margin: 0;
  }
  .bn-album {
    font-family: var(--font-serif);
    font-size: 20px;
    line-height: 1.15;
    font-weight: 500;
    color: var(--color-text);
    letter-spacing: -0.01em;
    margin: 0;
    transition: color 0.2s;
  }
  .bn-score {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-top: 4px;
  }
  .score-badge {
    display: flex;
    align-items: baseline;
    gap: 2px;
    font-family: var(--font-serif);
    font-weight: 600;
  }
  .score-num {
    font-size: 22px;
    letter-spacing: -0.02em;
    line-height: 1;
    color: var(--color-text);
  }
  .score-denom {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-faded);
  }
  .bnm-badge {
    font-family: var(--font-mono);
    font-size: 9px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-bg);
    background: var(--color-accent);
    padding: 2px 6px;
  }

  @media (max-width: 1024px) {
    .bestnew-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 640px) {
    .bestnew {
      padding: 36px 0;
    }
    .bestnew-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 18px;
    }
  }
</style>
