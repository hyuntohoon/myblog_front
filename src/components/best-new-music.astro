---
import type { CollectionEntry } from 'astro:content'
import PartialStars from '@components/partial-stars.astro'

export interface Props {
  posts: CollectionEntry<'blog'>[]
}

const { posts } = Astro.props

if (posts.length === 0) {
  // eslint-disable-next-line no-useless-return
  return
}
---

<section class="bestnew">
  <!-- Section header -->
  <div class="section-head">
    <div class="rule-label">
      <span class="rule-dot" style="background: var(--color-accent);"></span>
      <span>Best New Music</span>
    </div>
    <a href="/reviews/?bnm=1" class="section-link">모두 보기 →</a>
  </div>

  <!-- 4-column grid -->
  <ul class="bestnew-grid">
    {posts.slice(0, 4).map((post) => {
      const { title, slug, date, albumCover, image, musicReview, rating, ratingScale, bestNew } = post.data
      const cover = albumCover || image || musicReview?.cover?.src
      const artist = musicReview?.artists?.join(', ')
      const albumTitle = musicReview?.title
      const ratingValue = rating ?? musicReview?.rating?.value ?? null
      const ratingScaleEff = rating != null ? ratingScale : musicReview?.rating?.scale ?? 5
      const stars = ratingValue == null ? null : ratingScaleEff === 10 ? ratingValue / 2 : ratingValue

      return (
        <li>
          <a href={`/blog/${slug}`} class="bn-card">
            <!-- Cover -->
            <div class="bn-cover">
              {bestNew && <span class="bn-bnm">Best New</span>}
              {cover ?
(
                <img
	src={cover}
	alt={albumTitle ?? title}
	loading="lazy"
	class="bn-img"
                />
              ) :
(
                <div class="bn-placeholder">
                  <span>{(albumTitle ?? title).slice(0, 2).toUpperCase()}</span>
                </div>
              )}
            </div>

            <!-- Meta -->
            <div class="bn-meta">
              {artist && <p class="bn-artist">{artist}</p>}
              <p class="bn-album">{albumTitle ?? title}</p>
              <div class="bn-stars">
                {stars != null ?
(
                  <PartialStars value={stars} size={15} ariaLabel={`별점 ${stars} / 5`} />
                ) :
(
                  <span class="mono-label" style="color: var(--color-faded);">
                    {new Date(date).toLocaleDateString('ko-KR', { month: 'short', day: 'numeric' })}
                  </span>
                )}
              </div>
            </div>
          </a>
        </li>
      )
    })}
  </ul>
</section>

<style>
  .bestnew {
    padding: 56px 0;
    border-bottom: 1px solid var(--color-border);
  }
  .section-head {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 28px;
  }
  .rule-label {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text);
  }
  .rule-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .section-link {
    font-family: var(--font-mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-subtle);
    text-decoration: none;
    transition: color 0.2s;
  }
  .section-link:hover {
    color: var(--color-accent);
  }

  /* Grid */
  .bestnew-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 28px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  /* Card */
  .bn-card {
    display: flex;
    flex-direction: column;
    gap: 10px;
    text-decoration: none;
    color: inherit;
  }
  .bn-card:hover .bn-cover {
    transform: translateY(-3px);
  }
  .bn-card:hover .bn-album {
    color: var(--color-accent);
  }
  .bn-cover {
    position: relative;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    border: 1px solid var(--color-border-soft);
    transition: transform 0.35s cubic-bezier(0.2, 0, 0.2, 1);
  }
  .bn-bnm {
    position: absolute;
    top: 0;
    left: 0;
    z-index: 2;
    font-family: var(--font-mono);
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-on-accent, #fff);
    background: var(--color-accent);
    padding: 4px 7px;
  }
  .bn-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .bn-placeholder {
    width: 100%;
    height: 100%;
    background: var(--color-paper);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-serif);
    font-size: 32px;
    font-style: italic;
    font-weight: 700;
    color: var(--color-faded);
  }
  .bn-meta {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .bn-artist {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text);
    margin: 0;
  }
  .bn-album {
    font-family: var(--font-serif);
    font-size: 20px;
    line-height: 1.15;
    font-weight: 500;
    color: var(--color-text);
    letter-spacing: -0.01em;
    margin: 0;
    transition: color 0.2s;
  }
  .bn-stars {
    display: flex;
    align-items: center;
    margin-top: 4px;
  }

  @media (max-width: 1024px) {
    .bestnew-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 640px) {
    .bestnew {
      padding: 36px 0;
    }
    .bestnew-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 18px;
    }
  }
</style>
