---
/**
 * FEAT-header-scroll-prefs — Header scroll-behavior picker.
 * Lets the reader choose how the site header reacts to scrolling. Persisted in
 * localStorage (`atmb-header-scroll`) and applied live via the
 * `atmb:header-scroll-change` window event that header.client.ts listens for.
 * Mirrors the theme/accent select pattern alongside it in the footer.
 */
import Icon from './icon.astro'

const MODES = [
  { value: 'hide-down', label: '스크롤 시 숨김' },
  { value: 'compact', label: '스크롤 시 축소' },
  { value: 'threshold', label: '임계점 후 숨김' },
]
---

<atmb-header-scroll-select>
  <label class="relative flex items-center gap-2">
    <span class="sr-only">헤더 스크롤 동작</span>
    <Icon name="down-caret" class="icon label-icon" />
    <select autocomplete="off">
      {MODES.map(({ value, label }) => <option value={value}>{label}</option>)}
    </select>
  </label>
</atmb-header-scroll-select>

<script>
  type ScrollMode = 'hide-down' | 'compact' | 'threshold'
  const KEY = 'atmb-header-scroll'

  function parseMode(v: unknown): ScrollMode {
    return v === 'compact' || v === 'threshold' ? v : 'hide-down'
  }

  class AtmbHeaderScrollSelect extends HTMLElement {
    constructor() {
      super()
      const select = this.querySelector('select')
      if (!select)
        return
      select.value = parseMode(typeof localStorage !== 'undefined' && localStorage.getItem(KEY))
      select.addEventListener('change', () => {
        const mode = parseMode(select.value)
        try {
          localStorage.setItem(KEY, mode)
        }
        catch { /* quota */ }
        window.dispatchEvent(new CustomEvent('atmb:header-scroll-change', { detail: mode }))
      })
    }
  }
  customElements.define('atmb-header-scroll-select', AtmbHeaderScrollSelect)
</script>
