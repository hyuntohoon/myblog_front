---
import { SITE } from '@constants'
import Search from './search.astro'

const { pathname } = Astro.url

function normalize(p: string) {
  if (!p.startsWith('/'))
p = `/${p}`
  // Keep the query/hash out of the trailing-slash logic, else a link like
  // /reviews?bnm=1 would normalize to /reviews?bnm=1/ (broken).
  const qIndex = p.search(/[?#]/)
  const path = qIndex === -1 ? p : p.slice(0, qIndex)
  const rest = qIndex === -1 ? '' : p.slice(qIndex)
  return (path.endsWith('/') ? path : `${path}/`) + rest
}

// Compare by path only — a filtered link (e.g. /reviews?bnm=1) is still "on"
// the same page as its base route.
const pathOnly = (url: string) => normalize(url.split(/[?#]/)[0])
const isActive = (url: string) => pathOnly(pathname) === pathOnly(url)

const navLinks = [
  { title: 'Reviews', url: '/reviews' },
  { title: 'Archive', url: '/blog' },
  // Best New Music is a filter on the reviews index, not a category route.
  // The old /blog/category/review slug never existed (writer slug is
  // "best new music"/"reviews"), so it 404'd. ReviewsIndex reads ?bnm=1.
  { title: 'Best New Music', url: '/reviews?bnm=1' },
]
---

<script src="../scripts/header.client.ts"></script>

<header class="sticky top-0 z-50" style="background: var(--color-bg);">

  <!-- Topbar -->
  <div class="container">
    <div class="topbar">
      <div class="topbar-l">
        <span id="topbar-date" class="topbar-date"></span>
        <span class="topbar-sep">·</span>
        <span class="topbar-issue">음악 비평</span>
      </div>
      <div class="topbar-r">
        <a id="write-link" href="/write" class="topbar-btn hidden">Write</a>
        <button id="login-btn" class="topbar-btn">Login</button>
        <button id="logout-btn" class="topbar-btn hidden">Logout</button>
      </div>
    </div>
  </div>

  <!-- Hairline top rule -->
  <div class="rule-ink"></div>

  <!-- Masthead: centered logo -->
  <div class="container">
    <div class="masthead-inner">
      <!-- Left meta -->
      <div class="masthead-meta-l">
        <span class="mono-label">Vol. I</span>
        <span class="mono-label" style="color: var(--color-faded);">Music Review</span>
      </div>

      <!-- Logo (centered) -->
      <a href="/" aria-label={`${SITE.title} — 홈으로`}>
        <h1 class="logo">
          <em>{SITE.title}</em>
        </h1>
      </a>

      <!-- Right meta -->
      <div class="masthead-meta-r">
        <Search />
      </div>
    </div>
  </div>

  <!-- Hairline bottom rule -->
  <div class="rule-ink" style="opacity: 0.85;"></div>

  <!-- Main nav -->
  <div class="container">
    <nav aria-label="Primary navigation" class="mainnav">
      {navLinks.map((link) => {
        const href = normalize(link.url)
        const active = isActive(link.url)
        return (
          <a
	href={href}
	class={`mainnav-link${active ? ' mainnav-active' : ''}`}
	aria-current={active ? 'page' : undefined}
          >
            {link.title}
          </a>
        )
      })}
    </nav>
  </div>

  <!-- Hairline bottom border -->
  <div style="height:1px; background: var(--color-border);"></div>

</header>

<style>
  /* ── Topbar ── */
  .topbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 8px 0;
    font-family: var(--font-mono);
    font-size: 10.5px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-subtle);
    border-bottom: 1px solid var(--color-border-soft);
  }
  .topbar-l,
  .topbar-r {
    display: flex;
    gap: 14px;
    align-items: center;
  }
  .topbar-sep {
    color: var(--color-faded);
  }
  .topbar-btn {
    background: transparent;
    border: none;
    padding: 0;
    font-family: var(--font-mono);
    font-size: 10.5px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-subtle);
    cursor: pointer;
    transition: color 0.2s;
  }
  .topbar-btn:hover {
    color: var(--color-text);
  }

  /* ── Masthead ── */
  .masthead-inner {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    padding: 20px 0 22px;
    gap: 24px;
  }
  .masthead-meta-l {
    display: flex;
    flex-direction: column;
    gap: 3px;
  }
  .masthead-meta-r {
    display: flex;
    justify-content: flex-end;
    align-items: center;
  }

  /* ── Logo ── */
  .logo {
    margin: 0;
    font-family: var(--font-serif);
    font-weight: 600;
    font-size: clamp(40px, 7vw, 80px);
    letter-spacing: -0.04em;
    line-height: 0.92;
    text-align: center;
    color: var(--color-text);
    transition: color 0.2s;
  }
  .logo em {
    font-style: italic;
  }
  .logo:hover {
    color: var(--color-accent);
  }

  /* ── Nav ── */
  .mainnav {
    display: flex;
    justify-content: center;
    gap: 36px;
    padding: 12px 0;
    font-family: var(--font-sans);
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.02em;
  }
  .mainnav-link {
    position: relative;
    padding: 4px 0;
    color: var(--color-text);
    text-decoration: none;
    transition: color 0.2s;
  }
  /* Animated accent underline on hover */
  .mainnav-link::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: -2px;
    height: 1px;
    background: var(--color-accent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .mainnav-link:hover {
    color: var(--color-accent);
  }
  .mainnav-link:hover::after {
    transform: scaleX(1);
  }
  /* Active state */
  .mainnav-active {
    color: var(--color-highlight);
    font-weight: 600;
  }
  .mainnav-active::after {
    transform: scaleX(1);
  }

  /* ── Mobile: hide nav ── */
  @media (max-width: 640px) {
    .mainnav {
      gap: 20px;
      font-size: 12px;
    }
    .masthead-meta-l {
      display: none;
    }
    .masthead-inner {
      grid-template-columns: 1fr auto;
    }
  }
</style>

<script is:inline>
  /* Inject today's date into topbar */
  const dateEl = document.getElementById('topbar-date')
  if (dateEl) {
    const d = new Date()
    dateEl.textContent = d.toLocaleDateString('ko-KR', {
      year: 'numeric',
month: 'long',
day: 'numeric',
  })
  }
</script>
