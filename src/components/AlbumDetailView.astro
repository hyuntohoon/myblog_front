---
import type { components } from '../lib/api.gen'

type AlbumDetail = components['schemas']['Music_AlbumDetail']

const { detail } = Astro.props as { detail: AlbumDetail }

const album = detail.album
const artists = detail.artists ?? []
const tracks = detail.tracks ?? []

const spotifyUrl = album.spotify_id ?
  `https://open.spotify.com/album/${album.spotify_id}` :
  null

function fmt(sec?: number | null) {
  if (sec == null || Number.isNaN(sec))
return ''
  const m = Math.floor(sec / 60)
  const s = sec % 60
  return `${String(m).padStart(2, '0')}:${String(s).padStart(2, '0')}`
}

function joinFeat(names?: string[] | null) {
  if (!names || names.length === 0)
return ''
  return names.join(', ')
}

const primaryArtists = artists.map(a => a.name).join(', ')
const release = album.release_date ?? ''
const label = album.label ?? ''
const releaseLineParts = [release, label].filter(Boolean)
---

<style>
  .wrap {
    display: grid;
    grid-template-columns: 180px 1fr;
    gap: 1rem;
    padding: 1rem;
    border: 1px solid #e5e7eb;
    border-radius: 12px;
    background: #fff;
  }
  .cover {
    width: 180px;
    height: 180px;
    border-radius: 12px;
    overflow: hidden;
    background: #f3f4f6;
    border: 1px solid #e5e7eb;
  }
  .cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .meta {
    display: grid;
    gap: 0.35rem;
  }
  .title {
    font-size: 1.25rem;
    font-weight: 800;
    color: #111827;
    display: flex;
    gap: 0.5rem;
    align-items: center;
  }
  .badge {
    font-size: 0.75rem;
    font-weight: 700;
    padding: 0.15rem 0.45rem;
    border-radius: 999px;
    background: #ecfdf5;
    color: #065f46;
    border: 1px solid #a7f3d0;
  }
  .artist-line {
    color: #1f2937;
    font-size: 0.95rem;
  }
  .release-line {
    color: #6b7280;
    font-size: 0.85rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .release-line .sep {
    color: #cbd5e1;
  }
  .release-line .label {
    font-style: italic;
  }
  .row {
    display: flex;
    gap: 0.5rem;
    align-items: center;
    flex-wrap: wrap;
  }
  .link {
    color: #0ea5e9;
    text-decoration: none;
    font-weight: 700;
    font-size: 0.9rem;
  }
  .link:hover {
    text-decoration: underline;
  }
  .tracks {
    margin-top: 0.75rem;
    border-top: 1px solid #e5e7eb;
    padding-top: 0.75rem;
  }
  table {
    width: 100%;
    border-collapse: collapse;
  }
  th, td {
    text-align: left;
    padding: 0.5rem 0.4rem;
    border-bottom: 1px solid #f1f5f9;
  }
  th {
    color: #6b7280;
    font-weight: 700;
    font-size: 0.8rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }
  td {
    font-size: 0.95rem;
    vertical-align: baseline;
  }
  tbody tr {
    transition: background-color 0.12s ease-in-out;
  }
  tbody tr:hover {
    background-color: #fafafa;
  }
  .num {
    width: 3rem;
    color: #9ca3af;
    font-variant-numeric: tabular-nums;
  }
  .dur {
    width: 4.5rem;
    text-align: right;
    color: #6b7280;
    font-variant-numeric: tabular-nums;
  }
  .feat {
    color: #9ca3af;
    font-size: 0.85rem;
    margin-left: 0.4rem;
    font-style: italic;
  }
  .feat-prefix {
    font-style: normal;
    letter-spacing: 0.02em;
  }
</style>

<div class="wrap">
  <div class="cover">
    <img
	src={album.cover_url ?? 'https://placehold.co/600x600?text=No+Image'}
	alt={album.title}
    />
  </div>

  <div class="meta">
    <div class="title">
      <span>{album.title}</span>
      {album.album_type && <span class="badge">{album.album_type}</span>}
    </div>

    {primaryArtists && <div class="artist-line">{primaryArtists}</div>}

    {releaseLineParts.length > 0 && (
      <div class="release-line">
        {release && <span>{release}</span>}
        {release && label && <span class="sep">·</span>}
        {label && <span class="label">{label}</span>}
      </div>
    )}

    {spotifyUrl && (
      <div class="row">
        <a class="link" href={spotifyUrl} target="_blank" rel="noreferrer">
          Open in Spotify ↗
        </a>
      </div>
    )}

    <div class="tracks">
      <table>
        <thead>
          <tr>
            <th class="num">#</th>
            <th>Title</th>
            <th class="dur">Duration</th>
          </tr>
        </thead>
        <tbody>
          {tracks.map((t) => {
            const feat = joinFeat(t.feat_artist_names)
            return (
              <tr>
                <td class="num">{t.track_no ?? ''}</td>
                <td>
                  <span>{t.title}</span>
                  {feat && (
                    <span class="feat">
                      <span class="feat-prefix">feat.</span> {feat}
                    </span>
                  )}
                </td>
                <td class="dur">{fmt(t.duration_sec)}</td>
              </tr>
            )
          })}
        </tbody>
      </table>
    </div>
  </div>
</div>
