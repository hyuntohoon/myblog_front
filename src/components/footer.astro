---
/**
 * Site footer — Pitchfork-style flat link columns (music-magazine tone).
 *
 * A de-emphasized wordmark + a neutral one-liner, then equal-weight link columns
 * under mono kicker heads with hairline separators, and a plain copyright bar.
 * No author byline / persona stamp.
 *
 * ThemeSelect / AccentSelect are the REAL pickers (drive the document theme +
 * persist to localStorage), kept verbatim under the 보기 head.
 */
import ThemeSelect from './theme-select.astro'
import AccentSelect from './accent-select.astro'

const BROWSE = [
	{ label: 'Reviews', ko: '평론', href: '/reviews' },
	{ label: 'Genres', ko: '장르', href: '/genres' },
	{ label: 'Canon', ko: '명반', href: '/canon' },
	{ label: 'Collection', ko: '컬렉션', href: '/collection' },
]

const YEAR = new Date().getFullYear()
---

<footer class="container ef" aria-label="사이트 푸터">
	<hr class="ef-rule" />

	<div class="ef-main">
		{/* ① 워드마크 — 절제된 크기 + 중립 한 줄 */}
		<div class="ef-brand">
			<a href="/" class="ef-wordmark serif" aria-label="buckit — 홈으로">bucki<span class="accent">t</span></a>
			<p class="ef-tagline meta">음악을 듣고 · 쓰고 · 모으다</p>
		</div>

		{/* ② 둘러보기 */}
		<nav class="ef-col" aria-label="둘러보기">
			<div class="kicker ef-colhead">둘러보기</div>
			<ul class="ef-collist">
				{BROWSE.map(n => (
					<li>
						<a href={n.href} class="ef-collink">
							<span class="ef-collabel serif">{n.ko}</span>
							<span class="ef-colko meta">{n.label}</span>
						</a>
					</li>
				))}
			</ul>
		</nav>

		{/* ③ 구독 */}
		<nav class="ef-col" aria-label="구독">
			<div class="kicker ef-colhead">구독</div>
			<ul class="ef-collist">
				<li>
					<a href="/rss.xml" class="ef-collink ef-rss">
						<span class="ef-collabel serif">
							<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
								<path d="M4 11a9 9 0 0 1 9 9M4 4a16 16 0 0 1 16 16"></path>
								<circle cx="5" cy="19" r="1.4" fill="currentColor" stroke="none"></circle>
							</svg>
							RSS
						</span>
						<span class="ef-colko meta">피드</span>
					</a>
				</li>
			</ul>
		</nav>

		{/* ④ 보기 — 테마·액센트 피커 (실제 동작 컴포넌트 유지) */}
		<div class="ef-col ef-controls">
			<div class="kicker ef-colhead">보기</div>
			<div class="ef-ctl">
				<span class="meta ef-ctl-lab">테마</span>
				<ThemeSelect />
			</div>
			<div class="ef-ctl">
				<span class="meta ef-ctl-lab">액센트</span>
				<AccentSelect />
			</div>
		</div>
	</div>

	<hr class="ef-rule ef-rule-soft" />

	{/* ⑤ 저작권 + 미세 링크 */}
	<div class="ef-base">
		<span class="meta">© {YEAR} buckit</span>
		<div class="ef-base-links">
			<a href="/reviews" class="meta ef-mini">전체 색인</a>
			<a href="/rss.xml" class="meta ef-mini">RSS</a>
		</div>
	</div>
</footer>

<style>
	.ef {
		padding-bottom: 8px;
	}
	.ef-rule {
		height: 2px;
		background: var(--color-text);
		border: 0;
		margin: 0;
	}
	.ef-rule-soft {
		height: 1px;
		background: var(--color-border);
	}

	.ef-main {
		display: grid;
		grid-template-columns: 1.4fr 1fr 1fr auto;
		gap: clamp(22px, 4vw, 56px);
		padding: clamp(32px, 4.2vw, 48px) 0 clamp(28px, 3.6vw, 40px);
		align-items: start;
	}

	/* ① 워드마크 — 절제 */
	.ef-brand {
		min-width: 0;
	}
	.ef-wordmark {
		display: inline-block;
		font-size: clamp(22px, 2.4vw, 28px);
		font-weight: 600;
		letter-spacing: -0.03em;
		line-height: 1;
		color: var(--color-highlight);
		transition: color 0.15s;
	}
	.ef-wordmark:hover {
		color: var(--color-accent);
	}
	.ef-wordmark .accent {
		color: var(--color-accent);
	}
	.ef-tagline {
		margin: 14px 0 0;
		color: var(--color-faded);
		letter-spacing: 0.04em;
	}

	/* ②③④ 링크 컬럼 — 헤어라인 구분 (Pitchfork 평면 그리드) */
	.ef-col {
		min-width: 0;
		padding-left: clamp(16px, 2.4vw, 32px);
		border-left: 1px solid var(--color-border-soft);
	}
	.ef-colhead {
		color: var(--color-faded);
		margin-bottom: 14px;
	}
	.ef-collist {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 2px;
	}
	.ef-collink {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		gap: 16px;
		padding: 7px 0;
		border-bottom: 1px solid var(--color-border-soft);
		transition: padding-left 0.16s, border-color 0.16s;
	}
	.ef-collist li:last-child .ef-collink {
		border-bottom: 0;
	}
	.ef-collink:hover {
		padding-left: 6px;
		border-color: var(--color-border);
	}
	.ef-collabel {
		font-size: 17px;
		font-weight: 500;
		letter-spacing: -0.01em;
		color: var(--color-text);
		display: inline-flex;
		align-items: center;
		gap: 7px;
		white-space: nowrap;
		transition: color 0.15s;
	}
	.ef-colko {
		text-align: right;
		color: var(--color-faded);
	}
	.ef-collink:hover .ef-collabel {
		color: var(--color-accent);
	}
	.ef-rss .ef-collabel svg {
		color: var(--color-accent);
	}

	/* ④ 컨트롤 — 실제 피커 호스팅 */
	.ef-controls {
		display: flex;
		flex-direction: column;
		gap: 16px;
		min-width: 170px;
	}
	.ef-ctl {
		display: flex;
		flex-direction: column;
		gap: 9px;
		align-items: flex-start;
	}
	.ef-ctl-lab {
		color: var(--color-subtle);
	}

	/* ⑤ 저작권 */
	.ef-base {
		display: flex;
		align-items: center;
		justify-content: space-between;
		flex-wrap: wrap;
		gap: 14px;
		padding: 18px 0 clamp(22px, 3.6vw, 34px);
	}
	.ef-base-links {
		display: flex;
		gap: 20px;
	}
	.ef-mini {
		color: var(--color-faded);
		transition: color 0.15s;
	}
	.ef-mini:hover {
		color: var(--color-text);
	}

	/* ── 태블릿: 2열 (워드마크는 전체 폭) ── */
	@media (max-width: 820px) {
		.ef-main {
			grid-template-columns: 1fr 1fr;
			gap: 30px 28px;
		}
		.ef-brand {
			grid-column: 1 / -1;
			padding-bottom: 4px;
		}
		.ef-col {
			padding-left: 0;
			border-left: 0;
		}
	}
	@media (max-width: 480px) {
		.ef-main {
			grid-template-columns: 1fr;
			gap: 26px;
		}
		.ef-base {
			flex-direction: column;
			align-items: flex-start;
		}
		.ef-collabel {
			font-size: 16px;
		}
	}
</style>
