---
import Layout from '@layouts/layout.astro'
import Seo from '@components/seo.astro'
import Spacer from '@components/spacer.astro'
import SearchBar from '@components/search-bar.astro'
---

<Layout>
  <Seo slot="seo" title="앨범 평점 등록" />

  <main class="container py-8 max-w-2xl">
    <h1 class="text-2xl font-bold mb-6">앨범 평점 등록</h1>

    <form id="review-form" class="space-y-6">
      <!-- 앨범 검색 -->
      <section class="border border-gray-200 rounded px-4 py-4 space-y-3">
        <p class="text-sm text-gray-600 mb-2">앨범을 검색해서 선택하세요</p>
        <SearchBar />
        <div id="albumDetail" class="mt-2"></div>

        <!-- 선택된 앨범 표시 -->
        <div id="selected-album-wrap" class="hidden mt-3">
          <p class="text-xs text-gray-500 mb-1">선택된 앨범</p>
          <div id="selected-album" class="flex items-center gap-3 p-2 bg-slate-50 rounded"></div>
        </div>

        <!-- hidden inputs -->
        <input type="hidden" id="albumIds" name="album_ids" value="[]" />
        <input type="hidden" id="artistIds" name="artist_ids" value="[]" />
        <input type="hidden" id="albumCoverUrl" name="album_cover_url" value="" />
        <input type="hidden" id="albumTitle" name="album_title" value="" />
      </section>

      <!-- 평점 입력 -->
      <section id="rating-section" class="border border-gray-200 rounded px-4 py-4 hidden">
        <div class="flex items-center gap-4">
          <label for="rating" class="font-medium text-gray-700">평점</label>
          <input
            type="number"
            id="rating"
            name="rating"
            min="0"
            max="5"
            step="0.5"
            class="w-24 border border-gray-300 rounded px-3 py-2 text-lg text-center"
            placeholder="0~5"
            required
          />
          <span class="text-sm text-gray-400">/ 5</span>
          <div id="rating-stars" class="flex text-amber-400 text-xl"></div>
        </div>
        <p class="text-xs text-gray-400 mt-2">0.5 단위로 입력 (예: 3.5, 4, 4.5)</p>
      </section>

      <!-- 본문 (선택사항) -->
      <section class="border border-gray-200 rounded px-4 py-4">
        <button
          type="button"
          id="toggle-body"
          class="text-sm text-blue-600 hover:underline"
        >
          + 코멘트 추가 (선택)
        </button>
        <div id="body-section" class="hidden mt-3">
          <textarea
            id="body"
            name="body"
            rows="4"
            class="w-full border border-gray-300 rounded px-3 py-2 text-sm"
            placeholder="간단한 코멘트를 남겨보세요 (선택사항)"
          ></textarea>
        </div>
      </section>

      <!-- 제출 -->
      <div class="flex items-center gap-3">
        <button
          id="submit-btn"
          type="submit"
          class="bg-highlight text-white px-6 py-2 rounded hover:bg-opacity-80"
        >
          등록
        </button>
        <p id="result-msg" class="text-sm"></p>
      </div>
    </form>

    <Spacer axis="vertical" size={8} />
  </main>

  <script src="../scripts/albumDetail.client.ts"></script>
  <script src="../scripts/review/index.ts"></script>
</Layout>