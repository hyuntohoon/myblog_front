---
/* src/pages/settings/spotify/callback.astro — FEAT-multi-user 3b-e.
   Spotify authorize redirect target. The URL is registered byte-exact in the
   Spotify dashboard and in the backend's SPOTIFY_MEMBER_REDIRECT_URI
   (https://www.ratemymusic.blog/settings/spotify/callback — no trailing
   slash; the CloudFront viewer-request handler rewrites it to this page's
   index.html). Mirrors admin/callback.astro: self-contained, pre-theme. */
---

<!doctype html>
<html lang="ko">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<title>Spotify 연결 처리중…</title>
		<meta name="robots" content="noindex" />
	</head>
	<body>
		<main class="auth-callback" role="status" aria-live="polite">
			<div id="spinner" class="spinner" aria-hidden="true"></div>
			<p id="msg" class="caption">Spotify 연결 처리 중…</p>
			<button id="back" class="retry hidden" type="button">설정으로 돌아가기</button>
		</main>

		<script src="../../../scripts/spotify-callback.client.ts"></script>
	</body>
</html>

<style is:global>
	/* Self-contained styles: renders before the site theme provider, so colors */
	/* come from prefers-color-scheme rather than CSS vars (admin/callback idiom). */
	:root {
		color-scheme: light dark;
	}

	html,
	body {
		margin: 0;
		min-height: 100vh;
	}

	.auth-callback {
		display: flex;
		min-height: 100vh;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 1.25rem;
		padding: 1.5rem;
		background: #ffffff;
		color: #1a1a1a;
		font-family: ui-sans-serif, system-ui, -apple-system, "Segoe UI", sans-serif;
	}

	.spinner {
		width: 38px;
		height: 38px;
		border: 3px solid rgba(0, 0, 0, 0.12);
		border-top-color: #1a1a1a;
		border-radius: 50%;
		animation: auth-spin 0.8s linear infinite;
	}

	.caption {
		margin: 0;
		font-size: 0.95rem;
		letter-spacing: 0.01em;
		opacity: 0.75;
	}

	.retry {
		padding: 0.55rem 1.1rem;
		border: 1px solid currentColor;
		border-radius: 8px;
		background: transparent;
		color: inherit;
		font-size: 0.9rem;
		cursor: pointer;
	}

	.retry:hover {
		opacity: 0.8;
	}

	.hidden {
		display: none;
	}

	@keyframes auth-spin {
		to {
			transform: rotate(360deg);
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.spinner {
			animation-duration: 2s;
		}
	}

	@media (prefers-color-scheme: dark) {
		.auth-callback {
			background: #0f0f0f;
			color: #f2f2f2;
		}

		.spinner {
			border-color: rgba(255, 255, 255, 0.18);
			border-top-color: #f2f2f2;
		}
	}
</style>
