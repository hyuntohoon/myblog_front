---
import Layout from '@layouts/layout.astro'
import Seo from '@components/seo.astro'
import Spacer from '@components/spacer.astro'
import SearchBar from '@components/search-bar.astro'
---

<Layout>
  <Seo slot="seo" title="Rate an album" />

  <main class="container py-8">
    <h1 class="text-2xl font-bold mb-2">앨범 평점 남기기</h1>
    <p class="text-sm text-gray-500 mb-6">
      본문은 선택 사항이에요. 앨범 선택하고 평점만 저장해도 됩니다.
    </p>

    <form id="rating-write-form" class="space-y-6">
      {/* 제목 + 카테고리 */}
      <div class="flex flex-col gap-1">
        <div class="flex items-center gap-3">
          <input
            type="text"
            id="title"
            name="title"
            class="flex-1 border border-gray-300 px-3 py-2 rounded text-base"
            placeholder="제목 (예: [앨범명] 간단 평점)"
            required
          />
          <div class="flex items-center gap-2">
            <select
              name="category"
              id="category"
              class="border border-gray-300 px-3 py-2 rounded text-base w-32 md:w-40"
            >
              <option disabled selected>Loading...</option>
            </select>
            <button
              type="button"
              id="add-category"
              class="border border-dashed border-gray-400 px-3 py-2 rounded text-base hover:bg-muted"
            >
              +
            </button>
          </div>
        </div>
        <p id="titleError" class="text-xs text-red-500 hidden">
          제목을 입력하세요.
        </p>
      </div>

      {/* 음악 검색 + 앨범 선택 */}
      <section
        id="album-search-section"
        class="mt-2 border border-gray-200 rounded px-3 py-3 space-y-3"
      >
        <div class="flex items-center justify-between gap-2">
          <h2 class="text-sm font-semibold text-gray-700">
            앨범 선택
          </h2>
          <span class="text-[11px] text-gray-400">
            평점은 선택한 앨범 기준으로 저장됩니다.
          </span>
        </div>

        <SearchBar />
        <div id="albumDetail" class="mt-2"></div>

        {/* ✅ 평점 입력: 0–5, 0.5 step */}
        <div
          id="rating-section"
          class="mt-3 flex flex-wrap items-center gap-2 text-sm text-gray-700"
        >
          <label for="rating" class="shrink-0 font-medium">
            평점
          </label>
          <input
            type="number"
            id="rating"
            name="rating"
            min="0"
            max="5"
            step="0.5"
            class="w-20 border border-gray-300 rounded px-2 py-1 text-sm"
            placeholder="0–5"
            required
          />
          <span class="text-xs text-gray-400">0–5 (0.5 단위)</span>
          <div id="rating-stars" class="ml-2 flex text-amber-400 text-xs"></div>

          <p id="ratingError" class="text-[11px] text-red-500 hidden">
            0에서 5 사이의 값을 입력해주세요.
          </p>
        </div>

        {/* hidden inputs (백엔드에서 그대로 사용) */}
        <input type="hidden" id="albumIds" name="album_ids" value="[]" />
        <input type="hidden" id="artistIds" name="artist_ids" value="[]" />
      </section>

      {/* 본문 에디터 (선택 사항) */}
      <section class="space-y-2">
        <div class="flex items-center justify-between">
          <span class="text-sm font-semibold text-gray-700">
            본문 (선택)
          </span>
          <button
            type="button"
            id="toggle-editor"
            class="text-xs text-gray-500 underline underline-offset-2 hover:text-gray-700"
          >
            에디터 열기
          </button>
        </div>

        <div id="editor-wrapper" class="hidden">
          <div id="editor" class="border border-gray-300 rounded"></div>
          <textarea name="content" id="content" class="hidden"></textarea>
          <p class="mt-1 text-[11px] text-gray-400">
            글을 쓰고 싶을 때만 사용하세요. 비워두면 평점-only 포스트가 됩니다.
          </p>
        </div>
      </section>

      {/* 제출 */}
      <div class="flex items-center gap-3">
        <button
          id="submit-btn"
          type="submit"
          class="bg-highlight text-white px-4 py-2 rounded hover:bg-opacity-80 text-sm"
        >
          Save
        </button>
        <p id="write-result" class="text-xs mt-1"></p>
      </div>
    </form>

    <Spacer axis="vertical" size={8} />
  </main>

  {/* 스크립트 (기존 write 플로우 재사용) */}
  <script src="../scripts/write.guard.ts"></script>
  <script src="../scripts/albumDetail.client.ts"></script>
  <script src="../scripts/write/index.ts"></script>

  {/* 🔥 에디터 토글 + 평점 밸리데이션 보조 스크립트 */}
  <script>
    // 본문 에디터 토글
    const toggleBtn = document.getElementById('toggle-editor')
    const editorWrapper = document.getElementById('editor-wrapper')

    if (toggleBtn && editorWrapper) {
      toggleBtn.addEventListener('click', () => {
        const isHidden = editorWrapper.classList.contains('hidden')
        editorWrapper.classList.toggle('hidden', !isHidden)
        toggleBtn.textContent = isHidden ? '에디터 닫기' : '에디터 열기'
      })
    }

    // 평점 입력 간단 체크 (0–5)
    const ratingInput = document.getElementById('rating')
    const ratingError = document.getElementById('ratingError')
    const form = document.getElementById('rating-write-form')

    if (form && ratingInput && ratingError) {
      form.addEventListener('submit', (e) => {
        const value = parseFloat(ratingInput.value)
        if (Number.isNaN(value) || value < 0 || value > 5) {
          e.preventDefault()
          ratingError.classList.remove('hidden')
        } else {
          ratingError.classList.add('hidden')
        }
      })
    }
  </script>
</Layout>