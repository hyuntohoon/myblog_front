<script>
  // Scroll progress + font-size toggle. Co-located on this page only.
  const article = document.querySelector('.lfq-article') as HTMLElement | null
  if (article) {
    const fill = document.getElementById('lfqProgFill')
    const onScroll = () => {
      const doc = document.documentElement
      const h = doc.scrollHeight - doc.clientHeight
      const pct = h > 0 ? Math.min(100, Math.max(0, (doc.scrollTop / h) * 100)) : 0
      if (fill)
        fill.style.width = `${pct}%`
    }
    window.addEventListener('scroll', onScroll, { passive: true })
    onScroll()

    const buttons = article.querySelectorAll<HTMLButtonElement>('.lfq-size-btn')
    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const size = btn.dataset.size
        if (!size)
          return
        article.dataset.size = size
        buttons.forEach(b => b.classList.toggle('is-active', b === btn))
        try {
          localStorage.setItem('lfq-body-size', size)
        }
        catch { /* quota */ }
      })
    })
    try {
      const saved = localStorage.getItem('lfq-body-size')
      if (saved === 'sm' || saved === 'md' || saved === 'lg') {
        article.dataset.size = saved
        buttons.forEach(b => b.classList.toggle('is-active', b.dataset.size === saved))
      }
    }
 catch { /* ignore */ }
  }
</script>

