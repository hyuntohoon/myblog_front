---
import type { CollectionEntry } from 'astro:content'
import { getCollection, render } from 'astro:content'
import Seo from '@components/seo.astro'
import Layout from '@layouts/layout.astro'
import Prose from '@components/prose.astro'
import { SITE } from '@constants'
import { isoDateFormat } from '@utils'
import SkipNavContent from '@components/a11y/skip-nav-content.astro'
import Aside from '@components/aside.astro'
import Playground from '@components/playground.astro'
import ReviewHero from '@components/review-hero.astro'
import PartialStars from '@components/partial-stars.astro'
import { AddToBucketMenu } from '@components/member/pocket/AddToBucketMenu'
import ReviewTrackAdder from '@components/member/pocket/ReviewTrackAdder'
import { getArtistNameMap, resolveArtistLinks } from '@lib/artistNames'

export const prerender = true

export async function getStaticPaths() {
  const entries = await getCollection('blog')
  return entries.map(e => ({
    params: { slug: e.data.slug },
    props: { entry: e },
  }))
}

const { entry } = Astro.props as { entry: CollectionEntry<'blog'> }
const post = entry.data
const { Content } = await render(entry)

// FEAT-view-redesign Step 5: Lowfreq Article layout. The "review" branch
// renders when the post has at least one album OR a rating; otherwise the
// plain-hero ReviewHero handles it.
const isReview = (post.albumIds?.length ?? 0) > 0 || post.rating != null

// Read-time from raw markdown body (RFC Open Question #1 default — compute
// from word count when not provided). 220 wpm covers Korean+English mixed
// prose well enough for a kicker badge.
const wordCount = (entry.body ?? '').replace(/[#*_`>[\]()!\-]/g, ' ').trim().split(/\s+/).filter(Boolean).length
const readMinutes = Math.max(1, Math.round(wordCount / 220))

// Rating → 0-5 for partial stars (mirrors review-hero normalization).
const ratingForStars = post.rating != null ?
  (post.ratingScale === 10 ? post.rating / 2 : post.rating) :
  null

const publishedDate = new Date(post.date).toLocaleDateString('ko-KR', {
  year: 'numeric',
month: 'long',
day: 'numeric',
})

const releaseYear = post.musicReview?.releaseDate ?
  new Date(post.musicReview.releaseDate).getFullYear() :
  null
const artistText = post.musicReview?.artists?.join(', ') ?? null
// FEAT-artist-page link-in: link the byline to each subject artist's hub. Resolved
// from the post's canonical artistIds + authoritative catalog names; null (→ plain
// byline) when an id isn't a catalog artist or the build can't reach the API.
const artistLinks = resolveArtistLinks(post.artistIds, await getArtistNameMap())
const albumTitle = post.musicReview?.title ?? null
// FEAT-pocket-buckit Step 5b — the hero album is a PUBLIC bucket drop source.
// This page is prerendered + public, so an anonymous "담기" routes through the
// AddToBucketMenu logged-out handoff (pb:resume → Cognito → home PocketResume).
const heroAlbumId = post.albumIds?.[0] ?? null
const cover = post.albumCover || post.image || post.musicReview?.cover?.src
const genres = post.musicReview?.genres ?? []
const genreLabel = genres[0] ?? post.category ?? ''
// FEAT-genre-subgenres Step 3: editorial tier-1 sub-genre tags (the critic's
// precise genre call) — distinct from the machine tier-0 album `genres` above.
const subgenres = post.subgenres ?? []
const recordLabel = post.musicReview?.label ?? null
---

<Layout>
  <Seo
	slot="seo"
	forceTitle={post.title}
	description={post.description}
	image={post.albumCover || post.image}
	type="article"
  >
    <meta name="twitter:label1" content="Author" />
    <meta name="twitter:data1" content={SITE.defaultAuthor} />
    <meta name="article:published_time" content={isoDateFormat(post.date)} />
    <meta name="article:modified_time" content={isoDateFormat(post.lastUpdated)} />
    <meta name="article:section" content={post.category} />
  </Seo>

  <SkipNavContent>
    {!isReview && <ReviewHero post={post} />}

    {isReview && (
      <article class="lfq-article" data-size="md">
        <!-- Scroll progress bar -->
        <div class="lfq-prog" aria-hidden="true"><div class="lfq-prog-fill" id="lfqProgFill"></div></div>

        <!-- Font-size toggle -->
        <div class="lfq-size-toggle" role="group" aria-label="본문 크기">
          <button type="button" data-size="sm" class="lfq-size-btn" aria-label="작게">A−</button>
          <button type="button" data-size="md" class="lfq-size-btn is-active" aria-label="보통">A</button>
          <button type="button" data-size="lg" class="lfq-size-btn" aria-label="크게">A+</button>
        </div>

        <div class="lfq-shell">
          <!-- Header -->
          <header class="lfq-header">
            <div class="lfq-kicker">
              {genreLabel && <span class="lfq-kicker-item lfq-kicker-accent">{genreLabel.toUpperCase()}</span>}
              {genreLabel && <span class="lfq-kicker-sep">·</span>}
              <span class="lfq-kicker-item">{publishedDate}</span>
              <span class="lfq-kicker-sep">·</span>
              <span class="lfq-kicker-item">읽는 시간 {readMinutes}분</span>
              {post.bestNew && (
                <>
                  <span class="lfq-kicker-sep">·</span>
                  <span class="lfq-kicker-item lfq-kicker-bnm">BEST NEW MUSIC</span>
                </>
              )}
            </div>
            <h1 class="lfq-headline">{post.title}</h1>
            {post.description && <p class="lfq-dek"><em>{post.description}</em></p>}
            <div class="lfq-byline">
              <span class="mono-label">{SITE.defaultAuthor}</span>
              {post.postId && (
                <a class="lfq-edit-link mono-label" id="lfqEditLink" href={`/write?id=${post.postId}`} hidden>편집</a>
              )}
            </div>
          </header>

          <!-- Album hero -->
          <section class="lfq-hero">
            <div class="lfq-hero-cover">
              {cover ?
                <img src={cover} alt={albumTitle ?? post.title} loading="eager" /> :
                <div class="lfq-hero-placeholder">{(albumTitle ?? post.title).slice(0, 2).toUpperCase()}</div>}
            </div>
            <div class="lfq-hero-meta">
              {(recordLabel || releaseYear) && (
                <div class="lfq-hero-label">
                  {recordLabel && <span class="mono-label">{recordLabel}</span>}
                  {recordLabel && releaseYear && <span class="lfq-hero-dot">·</span>}
                  {releaseYear && <span class="mono-label">{releaseYear}</span>}
                </div>
              )}
              {artistLinks ?
                (
                  <p class="lfq-hero-artist">
                    {artistLinks.map((a, i) => (
                      <>{i > 0 ? ', ' : ''}<a class="lfq-hero-artist-link" href={`/artist/${a.id}/`}>{a.name}</a></>
                    ))}
                  </p>
                ) :
                (artistText && <p class="lfq-hero-artist">{artistText}</p>)}
              {albumTitle && <h2 class="lfq-hero-album"><em>{albumTitle}</em></h2>}
              {genres.length > 0 && (
                <p class="lfq-hero-genre">{genres.join(' · ')}</p>
              )}
              {subgenres.length > 0 && (
                <ul class="lfq-hero-subgenres" aria-label="서브장르">
                  {subgenres.map(sg => (
                    <li class="lfq-subgenre-chip">{sg.label}</li>
                  ))}
                </ul>
              )}
              {ratingForStars != null && (
                <div class="lfq-score">
                  <span class="mono-label lfq-score-label">SCORE</span>
                  <PartialStars value={ratingForStars} max={5} size={28} />
                </div>
              )}
              {heroAlbumId && (
                <div class="lfq-hero-actions">
                  <AddToBucketMenu client:only="react" item={{ albumId: heroAlbumId, title: albumTitle ?? post.title }} />
                </div>
              )}
            </div>
          </section>

          <!-- Hidden album-data containers consumed by albumDetail.fetch.client.ts -->
          <div
	id="music-section"
	data-album-ids={JSON.stringify(post.albumIds ?? [])}
	data-artist-ids={JSON.stringify(post.artistIds ?? [])}
	data-recommended-track-ids={JSON.stringify(post.recommendedTrackIds ?? [])}
	style="display: none;"
          ></div>

          <!-- Body: drop-cap, h2, accent pull-quote (via .lfq-prose globals below) -->
          <div class="lfq-prose">
            <Prose>
              <Content components={{ Aside, Playground }} />
            </Prose>
          </div>

          <!-- Track-by-track: full album tracklist with ★ on picks. -->
          {(post.albumIds?.length ?? 0) > 0 && (
            <section class="lfq-tracklist">
              <header class="lfq-tracklist-head">
                <span class="rule-dot-sm"></span>
                <span class="mono-label">트랙 바이 트랙</span>
                <span class="lfq-pick-legend">★ 추천 트랙</span>
              </header>
              <div id="albumDetail"></div>
              {/* FEAT-pocket-buckit Step 6 — bridges the vanilla tracklist's per-track
                  "담기" buttons to the shared AddToBucketMenu (track-as-bucket-member). */}
              <ReviewTrackAdder client:only="react" />
            </section>
          )}
        </div>
      </article>
    )}
  </SkipNavContent>
</Layout>

<style is:global>
  /* FEAT-view-redesign Step 5 — Lowfreq Article body globals.
     Scoped to .lfq-prose so plain (non-review) posts keep their default Prose styling. */
  .lfq-article {
    --body-size: 18px;
    --body-line: 1.78;
  }
  .lfq-article[data-size="sm"] { --body-size: 16px; --body-line: 1.7; }
  .lfq-article[data-size="md"] { --body-size: 18px; --body-line: 1.78; }
  .lfq-article[data-size="lg"] { --body-size: 20px; --body-line: 1.85; }

  .lfq-prose :global(p) {
    font-family: var(--font-serif);
    font-size: var(--body-size);
    line-height: var(--body-line);
    color: var(--color-text);
  }
  .lfq-prose :global(h2) {
    font-family: var(--font-serif);
    font-size: clamp(26px, 3.5vw, 36px);
    letter-spacing: -0.02em;
    line-height: 1.15;
    margin-top: 2.5em;
    margin-bottom: 0.6em;
    color: var(--color-text);
  }
  .lfq-prose :global(h3) {
    font-family: var(--font-serif);
    font-size: clamp(20px, 2.5vw, 26px);
    margin-top: 2em;
    margin-bottom: 0.5em;
  }
  /* Drop-cap on the first paragraph of the body */
  .lfq-prose :global(> p:first-of-type::first-letter),
  .lfq-prose :global(.prose > p:first-of-type::first-letter) {
    font-family: var(--font-serif);
    float: left;
    font-size: 4.2em;
    line-height: 0.9;
    padding: 0.05em 0.1em 0 0;
    font-weight: 600;
    color: var(--color-accent);
  }
  .lfq-prose :global(blockquote) {
    border-left: 3px solid var(--color-accent);
    padding-left: 1.4rem;
    margin: 1.8rem 0;
    font-family: var(--font-serif);
    font-style: italic;
    font-size: calc(var(--body-size) * 1.08);
    color: var(--color-text);
  }
  .lfq-prose :global(a) {
    color: var(--color-text);
    border-bottom: 1px solid var(--color-border);
    text-decoration: none;
    transition: border-color 0.2s, color 0.2s;
  }
  .lfq-prose :global(a:hover) {
    color: var(--color-accent);
    border-color: var(--color-accent);
  }

  /* Tracklist rows (injected by albumDetail.client.ts; must be :global). */
  .lfq-article :global(.lfq-tt-list) {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 2px;
  }
  .lfq-article :global(.lfq-tt-row) {
    display: grid;
    grid-template-columns: 3ch 1fr auto auto auto;
    gap: 14px;
    align-items: baseline;
    padding: 10px 0;
    border-bottom: 1px solid var(--color-border-soft);
    font-family: var(--font-serif);
    font-size: 16px;
    line-height: 1.4;
    color: var(--color-text);
  }
  .lfq-article :global(.lfq-tt-row.is-pick) {
    background: color-mix(in srgb, var(--color-accent) 4%, transparent);
    padding-left: 8px;
    padding-right: 8px;
    margin: 0 -8px;
  }
  .lfq-article :global(.lfq-tt-no) {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-faded);
    font-variant-numeric: tabular-nums;
  }
  .lfq-article :global(.lfq-tt-title) {
    color: var(--color-text);
  }
  .lfq-article :global(.lfq-tt-feat) {
    color: var(--color-subtle);
    font-style: italic;
    font-size: 0.9em;
    margin-left: 4px;
  }
  .lfq-article :global(.lfq-tt-feat-mark) {
    font-style: normal;
    font-family: var(--font-mono);
    font-size: 0.85em;
    letter-spacing: 0.03em;
  }
  .lfq-article :global(.lfq-tt-star) {
    color: var(--color-accent);
    margin-left: 6px;
  }
  .lfq-article :global(.lfq-tt-dur) {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-faded);
    font-variant-numeric: tabular-nums;
  }
  /* FEAT-pocket-buckit Step 5b — per-track play affordance (dormant until the
     owner provisions Spotify streaming) + the notice. Subtle, hover-revealed,
     so the editorial reading page stays calm. */
  .lfq-article :global(.lfq-tt-play),
  .lfq-article :global(.lfq-tt-add) {
    align-self: center;
    width: 24px;
    height: 24px;
    border-radius: 24px;
    display: grid;
    place-items: center;
    border: 1px solid var(--color-border);
    background: var(--color-bg);
    color: var(--color-subtle);
    font-size: 10px;
    line-height: 1;
    cursor: pointer;
    opacity: 0;
    transition: opacity 0.14s, color 0.14s, border-color 0.14s;
  }
  .lfq-article :global(.lfq-tt-add) { font-size: var(--text-base); }
  .lfq-article :global(.lfq-tt-row:hover .lfq-tt-play),
  .lfq-article :global(.lfq-tt-row:hover .lfq-tt-add),
  .lfq-article :global(.lfq-tt-play:focus-visible),
  .lfq-article :global(.lfq-tt-add:focus-visible) {
    opacity: 1;
  }
  .lfq-article :global(.lfq-tt-play:hover),
  .lfq-article :global(.lfq-tt-add:hover) {
    color: var(--color-accent);
    border-color: var(--color-accent);
  }
  /* Touch (no hover): the per-track actions can't hide behind hover — keep the
     non-drag "담기" path (WCAG 2.5.7) and play reachable on coarse pointers. */
  @media (hover: none) {
    .lfq-article :global(.lfq-tt-play),
    .lfq-article :global(.lfq-tt-add) { opacity: 1; }
  }
  .lfq-article :global(.lfq-tt-playnote) {
    margin-top: 12px;
    padding: 8px 12px;
    border-radius: 4px;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    line-height: 1.5;
    color: var(--color-subtle);
    background: color-mix(in srgb, var(--color-accent) 6%, var(--color-bg));
    border: 1px solid var(--color-border-soft);
    opacity: 0;
    transform: translateY(4px);
    transition: opacity 0.18s, transform 0.18s;
    pointer-events: none;
  }
  .lfq-article :global(.lfq-tt-playnote.is-on) {
    opacity: 1;
    transform: translateY(0);
  }
  .lfq-hero-actions {
    margin-top: 6px;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .lfq-article :global(.lfq-tt-empty) {
    font-family: var(--font-mono);
    font-size: var(--text-base);
    color: var(--color-faded);
    padding: 20px 0;
  }
</style>

<style>
  /* Scroll progress bar — fixed at the top of the viewport */
  .lfq-prog {
    position: fixed;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: transparent;
    z-index: var(--z-progress);
    pointer-events: none;
  }
  .lfq-prog-fill {
    height: 100%;
    width: 0%;
    background: var(--color-accent);
    transition: width 0.06s linear;
  }

  /* Font-size toggle — top-right small chip group */
  .lfq-size-toggle {
    position: sticky;
    top: 10px;
    z-index: var(--z-nav);
    display: flex;
    gap: 0;
    margin: 0 0 0 auto;
    width: fit-content;
    border: 1px solid var(--color-border);
    background: var(--color-bg);
  }
  .lfq-size-btn {
    background: transparent;
    border: none;
    padding: 0 12px;
    min-height: 38px;
    min-width: 40px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-faded);
    cursor: pointer;
    border-right: 1px solid var(--color-border);
  }
  .lfq-size-btn:last-child { border-right: none; }
  .lfq-size-btn:hover { color: var(--color-text); }
  .lfq-size-btn.is-active { background: var(--color-text); color: var(--color-bg); }

  .lfq-shell {
    /* The parent .container already supplies the side gutter (its padding),
       so a plain max-width here avoids double-gutter on narrow viewports. */
    max-width: var(--measure);
    margin: 0 auto;
    padding: 24px 0 80px;
  }

  /* Pitchfork-style break-out: header + album hero + tracklist extend past the
     prose measure to --measure-wide, staying centered on the column. The reading
     prose keeps the narrow --measure for readability. */
  .lfq-header,
  .lfq-hero,
  .lfq-tracklist {
    width: min(var(--measure-wide), 100vw - 2 * var(--space-4));
    margin-left: calc(50% - min(var(--measure-wide), 100vw - 2 * var(--space-4)) / 2);
  }

  /* ──────── Header ──────── */
  .lfq-header {
    padding: 40px 0 36px;
  }
  .lfq-kicker {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-subtle);
    margin-bottom: 18px;
  }
  .lfq-kicker-accent { color: var(--color-accent); font-weight: 600; }
  .lfq-kicker-bnm {
    color: var(--color-bg);
    background: var(--color-accent);
    padding: 2px 8px;
    letter-spacing: 0.1em;
  }
  .lfq-kicker-sep { opacity: 0.5; }
  .lfq-headline {
    margin: 0 0 14px;
    font-family: var(--font-serif);
    font-size: clamp(36px, 5vw, 58px);
    line-height: 1.02;
    letter-spacing: -0.025em;
    font-weight: 500;
    color: var(--color-text);
    overflow-wrap: anywhere;
  }
  .lfq-dek {
    margin: 0 0 18px;
    font-family: var(--font-serif);
    font-size: clamp(18px, 2vw, 22px);
    line-height: 1.5;
    color: var(--color-subtle);
  }
  .lfq-dek em { font-style: italic; }
  .lfq-byline {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 16px;
    padding-top: 14px;
    border-top: 1px solid var(--color-border);
  }
  /* Author-only edit affordance — unhidden client-side when isLoggedIn(). */
  .lfq-edit-link {
    color: var(--color-subtle);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    padding-bottom: 1px;
    transition: color 0.2s, border-color 0.2s;
  }
  .lfq-edit-link:hover {
    color: var(--color-text);
    border-color: var(--color-text);
  }

  /* ──────── Album hero ──────── */
  .lfq-hero {
    display: grid;
    grid-template-columns: 280px minmax(0, 1fr);
    gap: 40px;
    align-items: start;
    padding: 32px 0 36px;
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 36px;
  }
  .lfq-hero-cover {
    width: 280px;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    border: 1px solid var(--color-border-soft);
    background: var(--color-paper);
  }
  .lfq-hero-cover img {
    width: 100%; height: 100%;
    object-fit: cover;
    display: block;
  }
  .lfq-hero-placeholder {
    width: 100%; height: 100%;
    display: flex; align-items: center; justify-content: center;
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 64px;
    color: var(--color-faded);
  }
  .lfq-hero-meta { display: flex; flex-direction: column; gap: 10px; }
  .lfq-hero-label {
    display: flex;
    align-items: baseline;
    gap: 8px;
    flex-wrap: wrap;
  }
  /* audit L15: lift the record-label/year credit from faded to subtle so it
     reads clearly (faded passes AA but sits right at the floor at 10.5px). */
  .lfq-hero-label .mono-label { color: var(--color-subtle); }
  .lfq-hero-dot { color: var(--color-subtle); }
  .lfq-hero-artist {
    font-family: var(--font-mono);
    font-size: var(--text-base);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-text);
    margin: 0;
    overflow-wrap: anywhere;
  }
  .lfq-hero-artist-link {
    color: inherit;
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: color 0.14s, border-color 0.14s;
  }
  .lfq-hero-artist-link:hover {
    color: var(--color-accent);
    border-bottom-color: currentColor;
  }
  .lfq-hero-album {
    margin: 0;
    font-family: var(--font-serif);
    font-size: clamp(28px, 3.5vw, 40px);
    font-weight: 500;
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: var(--color-text);
    overflow-wrap: anywhere;
  }
  .lfq-hero-album em { font-style: italic; }
  .lfq-hero-genre {
    margin: 0;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-subtle);
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }
  /* FEAT-genre-subgenres Step 3: editorial sub-genre chips — the critic's
     precise genre call, distinct from the machine .lfq-hero-genre line above. */
  .lfq-hero-subgenres {
    list-style: none;
    margin: 10px 0 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }
  .lfq-subgenre-chip {
    font-family: var(--font-sans);
    font-size: 11.5px;
    line-height: 1;
    color: var(--color-text);
    background: var(--color-paper);
    padding: 5px 11px;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    white-space: nowrap;
  }
  /* Accent-bordered score card (RFC: stars only, no number) */
