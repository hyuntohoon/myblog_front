---
import Layout from '@layouts/layout.astro'
import Seo from '@components/seo.astro'
import SearchBar from '@components/search-bar.astro'
---

<Layout>
  <Seo slot="seo" title="Write — RAMAMU" />

  <main class="container write-main">

    <!-- Page title -->
    <div class="write-header">
      <h1 class="write-heading">New Post</h1>
      <span class="mono-label" style="color: var(--color-faded);">Draft</span>
    </div>

    <form id="write-form" class="write-layout" novalidate>

      <!-- ── LEFT: title / category / body ── -->
      <div class="write-left">

        <!-- Title -->
        <div class="field-group">
          <input
            type="text"
            id="title"
            name="title"
            class="write-title-input"
            placeholder="제목을 입력하세요"
            required
            autocomplete="off"
          />
          <p id="titleError" class="field-error hidden">제목을 입력하세요.</p>
        </div>

        <!-- Category row -->
        <div class="category-row">
          <select name="category" id="category" class="write-select">
            <option disabled selected>카테고리 로딩 중…</option>
          </select>
          <button type="button" id="add-category" class="add-cat-btn" title="새 카테고리 추가">
            + New
          </button>
        </div>

        <!-- Body editor -->
        <div class="editor-wrap">
          <div id="editor"></div>
          <textarea name="content" id="content" class="sr-only" aria-hidden="true"></textarea>
        </div>

      </div>

      <!-- ── RIGHT: music search / album / rating / submit ── -->
      <aside class="write-right">

        <!-- Music search -->
        <div class="right-section">
          <div class="right-section-label">
            <span class="rule-dot-sm"></span>
            <span class="mono-label">Music</span>
          </div>
          <div id="album-search-section">
            <SearchBar />
            <div id="albumDetail" class="mt-3"></div>
          </div>
        </div>

        <!-- Rating (shown after album selected) -->
        <div id="rating-section" class="right-section hidden">
          <div class="right-section-label">
            <span class="rule-dot-sm"></span>
            <span class="mono-label">Rating</span>
          </div>
          <div class="rating-input-row">
            <input
              type="number"
              id="rating"
              name="rating"
              min="0"
              max="10"
              step="0.5"
              class="rating-input"
              placeholder="0.0"
            />
            <span class="rating-scale mono-label">/ 10</span>
            <div id="rating-stars" class="rating-stars"></div>
          </div>
          <p class="mono-label rating-hint" style="color: var(--color-faded);">0–10점, 0.5 단위</p>
        </div>

        <!-- Hidden album/artist ID inputs -->
        <input type="hidden" id="albumIds" name="album_ids" value="[]" />
        <input type="hidden" id="artistIds" name="artist_ids" value="[]" />

        <!-- Submit actions -->
        <div class="right-section submit-section">
          <button id="submit-btn" type="submit" class="btn-publish">
            Publish
          </button>
          <p id="write-result" class="write-result mono-label"></p>
        </div>

      </aside>

    </form>
  </main>

  <script src="../scripts/write.guard.ts"></script>
  <script src="../scripts/albumDetail.client.ts"></script>
  <script src="../scripts/write/index.ts"></script>
  <script>
    window.addEventListener('album:detail', () => {
      const ratingSection = document.getElementById('rating-section')
      if (ratingSection) ratingSection.classList.remove('hidden')
    })
  </script>
</Layout>

<style>
  .write-main {
    padding-top: 40px;
    padding-bottom: 80px;
  }

  /* Page heading */
  .write-header {
    display: flex;
    align-items: baseline;
    gap: 16px;
    margin-bottom: 32px;
    padding-bottom: 20px;
    border-bottom: 1px solid var(--color-border);
  }
  .write-heading {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 32px;
    font-weight: 500;
    letter-spacing: -0.025em;
    color: var(--color-text);
    margin: 0;
  }

  /* Two-column layout */
  .write-layout {
    display: grid;
    grid-template-columns: 1fr 360px;
    gap: 40px;
    align-items: start;
  }

  /* ── Left column ── */
  .write-left {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .field-group {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .write-title-input {
    width: 100%;
    background: transparent;
    border: none;
    border-bottom: 1px solid var(--color-border);
    outline: none;
    font-family: var(--font-serif);
    font-size: 28px;
    font-style: italic;
    font-weight: 500;
    letter-spacing: -0.02em;
    color: var(--color-text);
    padding: 8px 0;
    transition: border-color 0.2s;
  }
  .write-title-input::placeholder {
    color: var(--color-faded);
    font-style: italic;
  }
  .write-title-input:focus {
    border-color: var(--color-text);
  }

  .field-error {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.04em;
    color: var(--color-accent);
    margin: 0;
  }

  .category-row {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .write-select {
    flex: 1;
    background: transparent;
    border: 1px solid var(--color-border);
    padding: 8px 12px;
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.04em;
    color: var(--color-text);
    outline: none;
    cursor: pointer;
    transition: border-color 0.2s;
  }
  .write-select:focus {
    border-color: var(--color-text);
  }
  .add-cat-btn {
    background: transparent;
    border: 1px dashed var(--color-border);
    padding: 8px 14px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-subtle);
    cursor: pointer;
    white-space: nowrap;
    transition: border-color 0.2s, color 0.2s;
  }
  .add-cat-btn:hover {
    border-color: var(--color-text);
    color: var(--color-text);
  }

  .editor-wrap {
    min-height: 480px;
    border: 1px solid var(--color-border);
  }

  /* ── Right column (sticky) ── */
  .write-right {
    position: sticky;
    top: 24px;
    display: flex;
    flex-direction: column;
    gap: 0;
    border: 1px solid var(--color-border);
  }

  .right-section {
    padding: 18px 20px;
    border-bottom: 1px solid var(--color-border-soft);
  }
  .right-section:last-child {
    border-bottom: none;
  }

  .right-section-label {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 14px;
  }
  .rule-dot-sm {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-text);
    flex-shrink: 0;
    opacity: 0.5;
  }

  /* Rating */
  .rating-input-row {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .rating-input {
    width: 72px;
    background: transparent;
    border: 1px solid var(--color-border);
    padding: 8px 12px;
    font-family: var(--font-serif);
    font-size: 22px;
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--color-text);
    outline: none;
    text-align: center;
    transition: border-color 0.2s;
    /* Remove number spinners */
    -moz-appearance: textfield;
  }
  .rating-input::-webkit-inner-spin-button,
  .rating-input::-webkit-outer-spin-button {
    -webkit-appearance: none;
  }
  .rating-input:focus {
    border-color: var(--color-text);
  }
  .rating-scale {
    color: var(--color-subtle);
    font-size: 14px;
  }
  .rating-stars {
    font-size: 18px;
    color: var(--color-accent);
    letter-spacing: -1px;
  }
  .rating-hint {
    margin-top: 8px;
    font-size: 10px;
  }

  /* Submit */
  .submit-section {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .btn-publish {
    width: 100%;
    background: var(--color-text);
    color: var(--color-bg);
    border: none;
    padding: 12px;
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    cursor: pointer;
    transition: opacity 0.2s;
  }
  .btn-publish:hover {
    opacity: 0.8;
  }
  .btn-publish:disabled {
    opacity: 0.4;
    cursor: not-allowed;
  }
  .write-result {
    font-size: 11px;
    color: var(--color-subtle);
    min-height: 1em;
  }

  /* Screen reader only */
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }

  /* Mobile: stack columns */
  @media (max-width: 900px) {
    .write-layout {
      grid-template-columns: 1fr;
    }
    .write-right {
      position: static;
    }
  }
</style>
