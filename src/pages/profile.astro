---
import Layout from '@layouts/layout.astro'
import Seo from '@components/seo.astro'
import SkipNavContent from '@components/a11y/skip-nav-content.astro'
import ProfileApp from '@components/member/ProfileApp'
import { getCollection } from 'astro:content'
import { computeStats, MEMBER_IDENTITY } from '@lib/member'
import { buildMemberReviews } from '@lib/reviewCollection'
import '@styles/member.css'
import '@styles/research.css'

// Mapper shared with /profile-reviews.json (profile-merge PR2) — see
// lib/reviewCollection.ts for the 평론 typing/normalization rules.
const reviews = buildMemberReviews(await getCollection('blog'))

const profile = { ...MEMBER_IDENTITY, stats: computeStats(reviews) }
---

<Layout>
  <Seo slot="seo" title="회원" />

  <SkipNavContent>
    <ProfileApp client:only="react" reviews={reviews} profile={profile} />
  </SkipNavContent>
</Layout>

<script src="../scripts/profile.guard.ts"></script>
