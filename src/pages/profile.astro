---
// Legacy owner-dashboard entry point. The unified member surface resolves the
// signed-in user at runtime and preserves dashboard tab deep links below.
const target = '/members/?me'
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="refresh" content={`0; url=${target}`} />
    <link rel="canonical" href={target} />
    <meta name="robots" content="noindex" />
    <title>회원 페이지 · buckit</title>
    <script is:inline define:vars={{ target }}>
      const tab = new URLSearchParams(location.search).get('tab')
      const destination = tab == null ? target : `${target}&tab=${encodeURIComponent(tab)}`
      location.replace(destination)
    </script>
  </head>
  <body>
    <p>회원 페이지로 이동 중… <a href={target}>바로 가기</a></p>
  </body>
</html>
