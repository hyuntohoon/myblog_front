---
import Layout from '@layouts/layout.astro'
import Seo from '@components/seo.astro'
import SkipNavContent from '@components/a11y/skip-nav-content.astro'
import ReviewsIndex from '@components/reviews/ReviewsIndex'
import { getCollection } from 'astro:content'
import { buildReviewCards } from '@lib/reviews'
import '@styles/reviews.css'

// Home is the interactive review browser (moved from /reviews). The normalized,
// JSON-safe array is handed to the React island.
const reviews = buildReviewCards(await getCollection('blog'))
---

<Layout>
  <Seo slot="seo" title="RAMAMU" />

  <SkipNavContent>
    <div class="container">
      <!-- Masthead -->
      <header class="rev-masthead">
        <h1 class="rev-title">Reviews</h1>
      </header>

      {reviews.length === 0 ?
(
        <div class="rev-empty">
          <p class="rev-empty-title">아직 리뷰가 없습니다</p>
          <p class="rev-empty-sub">첫 리뷰를 작성해 보세요.</p>
        </div>
      ) :
(
        <ReviewsIndex client:load reviews={reviews} />
      )}

      <!-- Footer -->
      <footer class="rev-footer">
        <span>RAMAMU</span>
      </footer>
    </div>
  </SkipNavContent>
</Layout>
