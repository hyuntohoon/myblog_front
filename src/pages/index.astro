---
import Layout from '@layouts/layout.astro'
import Seo from '@components/seo.astro'
import SkipNavContent from '@components/a11y/skip-nav-content.astro'
import HeroReview from '@components/hero-review.astro'
import BestNewMusic from '@components/best-new-music.astro'
import ReviewGrid from '@components/review-grid.astro'
import { getCollection } from 'astro:content'

function byDateDesc(a: { data: { date: string | Date } }, b: { data: { date: string | Date } }) {
  return new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
}

const allPosts = (await getCollection('blog')).sort(byDateDesc)

// Hero: most recent post that has a cover or musicReview
const heroPost =
  allPosts.find(p => p.data.albumCover || p.data.image || p.data.musicReview) ??
  allPosts[0]

// Best New Music: posts with high rating (>=8/10) that have a cover — cap at 4
const bestNewMusic = allPosts
  .filter(p => {
    const r = p.data.musicReview?.rating?.value
    return r != null && r >= 8
  })
  .slice(0, 4)

// Recent grid: exclude the hero post, show up to 9
const recentPosts = allPosts
  .filter(p => heroPost == null || p.id !== heroPost.id)
  .slice(0, 9)
---

<Layout>
  <Seo slot="seo" title="RAMAMU — 음악 비평" />

  <SkipNavContent>
    <div class="container">

      {heroPost ? (
        <HeroReview post={heroPost} />
      ) : (
        <!-- 빈 상태 -->
        <div class="empty-hero">
          <p class="mono-label" style="color: var(--color-faded);">
            아직 작성된 리뷰가 없습니다.
          </p>
        </div>
      )}

      {bestNewMusic.length > 0 && (
        <BestNewMusic posts={bestNewMusic} />
      )}

      {recentPosts.length > 0 && (
        <ReviewGrid posts={recentPosts} title="Latest Reviews" />
      )}

      {allPosts.length === 0 && (
        <div class="empty-state">
          <p class="empty-title">아직 리뷰가 없습니다</p>
          <p class="empty-sub">첫 리뷰를 작성해 보세요.</p>
          <a href="/write" class="empty-cta">Write →</a>
        </div>
      )}

    </div>
  </SkipNavContent>
</Layout>

<style>
  .empty-hero {
    padding: 80px 0;
    border-bottom: 1px solid var(--color-border);
    text-align: center;
  }
  .empty-state {
    padding: 120px 0;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
  }
  .empty-title {
    font-family: var(--font-serif);
    font-size: 32px;
    font-style: italic;
    color: var(--color-text);
    margin: 0;
  }
  .empty-sub {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-faded);
    margin: 0;
  }
  .empty-cta {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text);
    border-bottom: 1px solid currentColor;
    padding-bottom: 2px;
    text-decoration: none;
    margin-top: 8px;
    transition: opacity 0.2s;
  }
  .empty-cta:hover {
    opacity: 0.6;
  }
</style>
