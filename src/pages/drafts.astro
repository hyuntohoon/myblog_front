---
import Layout from '@layouts/layout.astro'
import Seo from '@components/seo.astro'
---

<Layout>
  <Seo slot="seo" title="내 글 — RAMAMU" noIndex />

  <main class="container drafts-main">

    <div class="drafts-header">
      <h1 class="drafts-heading">내 글</h1>
      <span class="mono-label" style="color: var(--color-faded);" id="draft-count">—</span>
    </div>

    <div class="view-tabs">
      <button type="button" class="view-tab active" data-view="draft">초안</button>
      <button type="button" class="view-tab" data-view="published">발행됨</button>
      <button type="button" class="view-tab" data-view="archived">보관함</button>
    </div>

    <div id="drafts-loading" class="drafts-empty">
      <p class="mono-label" style="color: var(--color-faded);">불러오는 중…</p>
    </div>

    <div id="drafts-error" class="drafts-empty hidden">
      <p class="mono-label" style="color: var(--color-accent);">불러오지 못했습니다.</p>
      <p class="mono-label" style="color: var(--color-faded); margin-top: 8px;">로그인 상태를 확인해주세요.</p>
    </div>

    <div id="drafts-empty-msg" class="drafts-empty hidden">
      <p class="drafts-empty-title" id="drafts-empty-title">임시저장된 글이 없습니다</p>
      <a href="/write" class="drafts-cta">새 글 작성 →</a>
    </div>

    <table id="drafts-table" class="drafts-table hidden">
      <thead>
        <tr>
          <th class="col-title">Title</th>
          <th class="col-cat">Category</th>
          <th class="col-date">작성일</th>
          <th class="col-action"></th>
        </tr>
      </thead>
      <tbody id="drafts-tbody"></tbody>
    </table>

    <div id="confirm-backdrop" class="confirm-backdrop hidden">
      <div class="confirm-modal" role="dialog" aria-modal="true" aria-labelledby="confirm-title">
        <h2 id="confirm-title" class="confirm-title">완전 삭제할까요?</h2>
        <p class="confirm-body">이 작업은 되돌릴 수 없습니다. 보관함에서도 복구할 수 없습니다. 관련 버킷 항목도 함께 삭제됩니다.</p>
        <div class="confirm-actions">
          <button type="button" class="confirm-cancel" id="confirm-cancel">취소</button>
          <button type="button" class="confirm-confirm" id="confirm-confirm">완전 삭제</button>
        </div>
      </div>
    </div>

    <div id="toast" class="drafts-toast hidden"></div>

  </main>
</Layout>

<style>
  .drafts-main {
    padding-top: 40px;
    padding-bottom: 80px;
  }
  .drafts-header {
    display: flex;
    align-items: baseline;
    gap: 16px;
    margin-bottom: 16px;
    padding-bottom: 20px;
    border-bottom: 1px solid var(--color-border);
  }
  .drafts-heading {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 32px;
    font-weight: 500;
    letter-spacing: -0.025em;
    color: var(--color-text);
    margin: 0;
  }
  .view-tabs {
    display: flex;
    gap: 16px;
    margin-bottom: 16px;
  }
  .view-tab {
    background: none;
    border: 1px solid var(--color-border);
    padding: 6px 14px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-subtle);
    cursor: pointer;
    transition: color 0.2s, border-color 0.2s;
  }
  .view-tab:hover {
    color: var(--color-text);
    border-color: var(--color-text);
  }
  .view-tab.active {
    color: var(--color-text);
    border-color: var(--color-text);
  }
  .drafts-empty {
    padding: 80px 0;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
  }
  .drafts-empty-title {
    font-family: var(--font-serif);
    font-size: 24px;
    font-style: italic;
    color: var(--color-text);
    margin: 0;
  }
  .drafts-cta {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text);
    border-bottom: 1px solid currentColor;
    padding-bottom: 2px;
    text-decoration: none;
    margin-top: 8px;
    transition: opacity 0.2s;
  }
  .drafts-cta:hover { opacity: 0.6; }
  .drafts-table {
    width: 100%;
    border-collapse: collapse;
  }
  .drafts-table thead {
    border-bottom: 1px solid var(--color-border);
  }
  .drafts-table th {
    font-family: var(--font-mono);
    font-size: 10.5px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-subtle);
    font-weight: 500;
    padding: 0 0 12px;
    text-align: left;
  }
  .col-title  { width: auto; }
  .col-cat    { width: 140px; }
  .col-date   { width: 160px; }
  .col-action { width: 220px; text-align: right; }
  .drafts-table td {
    padding: 18px 0;
    border-bottom: 1px solid var(--color-border-soft);
    vertical-align: middle;
  }
  .draft-title-cell {
    font-family: var(--font-serif);
    font-size: 17px;
    font-weight: 500;
    color: var(--color-text);
    letter-spacing: -0.01em;
  }
  .draft-cat-cell {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-subtle);
  }
  .draft-date-cell {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.04em;
    color: var(--color-faded);
  }
  .draft-actions {
    display: flex;
    justify-content: flex-end;
    gap: 12px;
  }
  .draft-action-link,
  .draft-action-btn {
    font-family: var(--font-mono);
    font-size: 10.5px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--color-subtle);
    border-bottom: 1px solid transparent;
    padding-bottom: 1px;
    cursor: pointer;
    background: none;
    border-top: none;
    border-left: none;
    border-right: none;
    transition: color 0.2s, border-color 0.2s;
  }
  .draft-action-link:hover,
  .draft-action-btn:hover {
    color: var(--color-text);
    border-color: var(--color-text);
  }
  .draft-action-btn.danger:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
  }
  .confirm-backdrop {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1000;
  }
  .confirm-modal {
    background: var(--color-bg, #fff);
    border: 1px solid var(--color-border);
    padding: 24px 28px;
    max-width: 420px;
    width: calc(100% - 32px);
  }
  .confirm-title {
    font-family: var(--font-serif);
    font-size: 20px;
    font-weight: 500;
    margin: 0 0 12px;
    color: var(--color-text);
  }
  .confirm-body {
    font-family: var(--font-serif);
    font-size: 14px;
    color: var(--color-subtle);
    margin: 0 0 24px;
    line-height: 1.6;
  }
  .confirm-actions {
    display: flex;
    justify-content: flex-end;
    gap: 16px;
  }
  .confirm-cancel,
  .confirm-confirm {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    background: none;
    border: 1px solid var(--color-border);
    padding: 8px 16px;
    cursor: pointer;
    color: var(--color-text);
    transition: color 0.2s, border-color 0.2s;
  }
  .confirm-confirm {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }
  .confirm-confirm:hover {
    background: var(--color-accent);
    color: var(--color-bg, #fff);
  }
  .confirm-cancel:hover {
    border-color: var(--color-text);
  }
  .drafts-toast {
    position: fixed;
    bottom: 32px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--color-text);
    color: var(--color-bg, #fff);
    padding: 12px 20px;
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.04em;
    z-index: 1001;
    transition: opacity 0.2s;
  }
  .hidden { display: none; }
</style>

<script>
  import { getAccessToken, goLogin, isLoggedIn } from '../lib/auth'

  const API = import.meta.env.PUBLIC_BACKEND_API_URL as string

  type View = 'draft' | 'published' | 'archived'
  let currentView: View = 'draft'

  const $loading = document.getElementById('drafts-loading')!
  const $error   = document.getElementById('drafts-error')!
  const $empty   = document.getElementById('drafts-empty-msg')!
  const $emptyTitle = document.getElementById('drafts-empty-title')!
  const $table   = document.getElementById('drafts-table')!
  const $tbody   = document.getElementById('drafts-tbody')!
  const $count   = document.getElementById('draft-count')!
  const $confirmBackdrop = document.getElementById('confirm-backdrop')!
  const $confirmCancel = document.getElementById('confirm-cancel')! as HTMLButtonElement
  const $confirmConfirm = document.getElementById('confirm-confirm')! as HTMLButtonElement
  const $toast = document.getElementById('toast')!

  const show = (el: HTMLElement) => el.classList.remove('hidden')
  const hide = (el: HTMLElement) => el.classList.add('hidden')

  let toastTimer: number | undefined
  function flash(msg: string) {
    $toast.textContent = msg
    show($toast)
    if (toastTimer)
window.clearTimeout(toastTimer)
    toastTimer = window.setTimeout(() => hide($toast), 2400)
  }

  function confirmHardDelete(): Promise<boolean> {
    return new Promise((resolve) => {
      show($confirmBackdrop)
      // Hoisted function declarations so cleanup can refer to the listener
      // identities — arrow consts would forward-reference and fail
      // ts/no-use-before-define.
      function onCancel() {
        finish(false)
      }
      function onConfirm() {
        finish(true)
      }
      function onBackdrop(e: Event) {
        if (e.target === $confirmBackdrop)
          finish(false)
      }
      function finish(result: boolean) {
        hide($confirmBackdrop)
        $confirmCancel.removeEventListener('click', onCancel)
        $confirmConfirm.removeEventListener('click', onConfirm)
        $confirmBackdrop.removeEventListener('click', onBackdrop)
        resolve(result)
      }
      $confirmCancel.addEventListener('click', onCancel)
      $confirmConfirm.addEventListener('click', onConfirm)
      $confirmBackdrop.addEventListener('click', onBackdrop)
    })
  }

  function formatDate(iso: string) {
    return new Date(iso).toLocaleDateString('ko-KR', {
      year: 'numeric',
      month: 'short',
      day: 'numeric',
    })
  }

  function authHeaders(): HeadersInit {
    const token = getAccessToken()
    return { Authorization: `Bearer ${token ?? ''}` }
  }

  function makeActionLink(text: string, href: string): HTMLAnchorElement {
    const a = document.createElement('a')
    a.className = 'draft-action-link'
    a.href = href
    a.textContent = text
    return a
  }

  function makeActionBtn(text: string, danger: boolean, onClick: () => void): HTMLButtonElement {
    const b = document.createElement('button')
    b.type = 'button'
    b.className = `draft-action-btn${danger ? ' danger' : ''}`
    b.textContent = text
    b.addEventListener('click', onClick)
    return b
  }

  function rowVanish(tr: HTMLTableRowElement) {
    tr.remove()
    const remaining = $tbody.querySelectorAll('tr').length
    $count.textContent = `${remaining}개`
    if (remaining === 0) {
      hide($table)
      show($empty)
    }
  }

  function makeRow(d: {
    id: string
    title: string
    slug: string
    category: string | null
    posted_date: string
  }): HTMLTableRowElement {
    const tr = document.createElement('tr')

    const tdTitle = document.createElement('td')
    tdTitle.className = 'draft-title-cell'
    tdTitle.textContent = d.title
    tr.appendChild(tdTitle)

    const tdCat = document.createElement('td')
    tdCat.className = 'draft-cat-cell'
    tdCat.textContent = d.category ?? '—'
    tr.appendChild(tdCat)

    const tdDate = document.createElement('td')
    tdDate.className = 'draft-date-cell'
    tdDate.textContent = formatDate(d.posted_date)
    tr.appendChild(tdDate)

    const tdActions = document.createElement('td')
    const actionsDiv = document.createElement('div')
    actionsDiv.className = 'draft-actions'

    if (currentView === 'draft' || currentView === 'published') {
      actionsDiv.appendChild(makeActionLink('편집', `/write?id=${encodeURIComponent(d.id)}`))
      // Both views soft-archive via DELETE (status→archived). For a published
      // post the backend also un-publishes the static MDX (Step 3); 복구 from
      // 보관함 re-publishes it. Only the label/toast differ.
      const isPublished = currentView === 'published'
      const archiveLabel = isPublished ? '발행 취소' : '보관'
      const archiveToast = isPublished ? '발행 취소됨 — 보관함에서 복구 가능' : '보관됨 — 복구 가능'
      actionsDiv.appendChild(makeActionBtn(archiveLabel, false, async () => {
        const r = await fetch(`${API}/api/posts/${encodeURIComponent(d.id)}`, {
          method: 'DELETE',
          headers: authHeaders(),
        })
        if (r.ok) {
          rowVanish(tr)
          flash(archiveToast)
        }
        else { flash(`${archiveLabel} 실패 (${r.status})`) }
      }))
    }
    else {
      actionsDiv.appendChild(makeActionBtn('복구', false, async () => {
        const r = await fetch(`${API}/api/posts/${encodeURIComponent(d.id)}/restore`, {
          method: 'PATCH',
          headers: authHeaders(),
        })
        if (r.ok) {
          rowVanish(tr)
          flash('복구 완료')
        }
        else { flash(`복구 실패 (${r.status})`) }
      }))
    }

    actionsDiv.appendChild(makeActionBtn('완전 삭제', true, async () => {
      if (!await confirmHardDelete())
return
      const r = await fetch(`${API}/api/posts/${encodeURIComponent(d.id)}?hard=true`, {
        method: 'DELETE',
        headers: authHeaders(),
      })
      if (r.ok) {
        rowVanish(tr)
        flash('완전 삭제됨')
      }
      else { flash(`삭제 실패 (${r.status})`) }
    }))

    tdActions.appendChild(actionsDiv)
    tr.appendChild(tdActions)

    return tr
  }

  async function loadPosts() {
    hide($error)
    hide($empty)
    hide($table)
    show($loading)
    $tbody.replaceChildren()

    if (!isLoggedIn()) {
      goLogin(false, '/drafts')
      return
    }
    try {
      const url = currentView === 'draft' ?
      `${API}/api/posts?status=draft` :
      currentView === 'published' ?
      `${API}/api/posts?status=published` :
      `${API}/api/posts?status=archived&include_archived=true`
      const res = await fetch(url, { headers: authHeaders() })
      if (!res.ok)
throw new Error(`HTTP ${res.status}`)

      const { posts } = await res.json() as {
        posts: Array<{
          id: string
          title: string
          slug: string
          category: string | null
          posted_date: string
        }>
      }

      hide($loading)

      if (posts.length === 0) {
        $count.textContent = '0개'
        $emptyTitle.textContent = currentView === 'draft' ?
        '임시저장된 글이 없습니다' :
        currentView === 'published' ?
        '발행된 글이 없습니다' :
        '보관함이 비어 있습니다'
        show($empty)
        return
      }

      $count.textContent = `${posts.length}개`
      posts.forEach(d => $tbody.appendChild(makeRow(d)))
      show($table)
    }
    catch {
      hide($loading)
      show($error)
    }
  }

  document.querySelectorAll<HTMLButtonElement>('.view-tab').forEach((btn) => {
    btn.addEventListener('click', () => {
      const next = btn.dataset.view as View
      if (next === currentView)
return
      currentView = next
      document.querySelectorAll('.view-tab').forEach(b => b.classList.remove('active'))
      btn.classList.add('active')
      loadPosts()
    })
  })

  loadPosts()
</script>
