---
// /buckets — a dedicated, discoverable entry point to the 평론 버킷 management
// surface. Redirects to the signed-in user's OWN member page bucket tab
// (audit 2026-07-14: the old /profile/?tab=bucket target sent members to the
// owner dashboard; /members/?me resolves self at runtime and its SelfDashboard
// hosts the same BucketBoard — works for the owner too). The `?tab=bucket`
// deeplink lands directly on it; not logged in → goLogin via the ?me path.
const target = '/members/?me&tab=bucket'
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="refresh" content={`0; url=${target}`} />
    <link rel="canonical" href={target} />
    <meta name="robots" content="noindex" />
    <title>버킷 관리 · buckit</title>
    <script is:inline define:vars={{ target }}>
      location.replace(target)
    </script>
  </head>
  <body>
    <p>버킷 관리 페이지로 이동 중… <a href={target}>바로 가기</a></p>
  </body>
</html>
