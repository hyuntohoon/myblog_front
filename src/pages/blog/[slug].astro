---
import type { CollectionEntry } from 'astro:content'
import { getCollection, render } from 'astro:content'
import Seo from '@components/seo.astro'
import Layout from '@layouts/layout.astro'
import Prose from '@components/prose.astro'
import { SITE } from '@constants'
import { isoDateFormat } from '@utils'
import SkipNavContent from '@components/a11y/skip-nav-content.astro'
import Aside from '@components/aside.astro'
import Playground from '@components/playground.astro'
import ReviewHero from '@components/review-hero.astro'

const detailClient = '/src/scripts/albumDetail.client.ts'
const detailFetchClient = '/src/scripts/albumDetail.fetch.client.ts'

export const prerender = true

export async function getStaticPaths() {
  const entries = await getCollection('blog')
  return entries.map(e => ({
    params: { slug: e.data.slug },
    props: { entry: e },
  }))
}

const { entry } = Astro.props as { entry: CollectionEntry<'blog'> }
const post = entry.data
const { Content } = await render(entry)
---

<Layout>
  <Seo
	slot="seo"
	forceTitle={post.title}
	description={post.description}
	image={post.albumCover || post.image}
	type="article"
  >
    <meta name="twitter:label1" content="Author" />
    <meta name="twitter:data1" data-pagefind-meta="author" content={SITE.defaultAuthor} />
    <meta name="article:published_time" data-pagefind-meta="published_time" content={isoDateFormat(post.date)} />
    <meta name="article:modified_time" data-pagefind-meta="modified_time" content={isoDateFormat(post.lastUpdated)} />
    <meta name="article:section" content={post.category} />
  </Seo>

  <SkipNavContent searchIndex={post.searchIndex}>
    <div class="container">

      <!-- Hero: album cover + rating or plain heading -->
      <ReviewHero post={post} />

      <!-- Hidden album data containers for fetch script -->
      <div
	id="music-section"
	data-album-ids={JSON.stringify(post.albumIds ?? [])}
	data-artist-ids={JSON.stringify(post.artistIds ?? [])}
	style="display: none;"
      ></div>

      <!-- Article body: narrow centered column -->
      <div class="article-wrap">
        <Prose>
          <Content components={{ Aside, Playground }} />
        </Prose>
      </div>

      <!-- Album detail: tracklist injected by albumDetail.client.ts -->
      {(post.albumIds?.length ?? 0) > 0 && (
        <div class="tracklist-section">
          <div class="tracklist-label">
            <span class="rule-dot-sm"></span>
            <span class="mono-label">Tracklist</span>
          </div>
          <div id="albumDetail"></div>
        </div>
      )}

    </div>
  </SkipNavContent>
</Layout>

<style>
  /* Narrow body column: editorial single-column */
  .article-wrap {
    max-width: 680px;
    margin: 0 auto;
    padding: 56px 0 48px;
  }

  /* Tracklist section */
  .tracklist-section {
    border-top: 1px solid var(--color-border);
    padding: 40px 0 64px;
    max-width: 680px;
    margin: 0 auto;
  }
  .tracklist-label {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 24px;
  }
  .rule-dot-sm {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-text);
    flex-shrink: 0;
    opacity: 0.6;
  }

  /* Override Prose defaults for editorial feel */
  .article-wrap :global(h1) {
    font-family: var(--font-serif);
    font-style: italic;
  }
  .article-wrap :global(h2),
  .article-wrap :global(h3) {
    font-family: var(--font-serif);
    letter-spacing: -0.02em;
  }
  .article-wrap :global(p) {
    font-family: var(--font-serif);
    font-size: 1.125rem;
    line-height: 1.75;
    color: var(--color-text);
  }
  .article-wrap :global(a) {
    color: var(--color-text);
    border-bottom: 1px solid var(--color-border);
    text-decoration: none;
    transition: border-color 0.2s, color 0.2s;
  }
  .article-wrap :global(a:hover) {
    color: var(--color-accent);
    border-color: var(--color-accent);
  }
  .article-wrap :global(blockquote) {
    border-left: 2px solid var(--color-accent);
    padding-left: 1.5rem;
    font-style: italic;
    color: var(--color-subtle);
  }

  @media (max-width: 768px) {
    .article-wrap {
      padding: 36px 0 36px;
    }
  }
</style>

<script type="module" src={detailClient}></script>
<script type="module" src={detailFetchClient}></script>
