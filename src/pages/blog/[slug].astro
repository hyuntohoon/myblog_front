---
// Legacy /blog/[slug] → /review/[slug] redirect stub (FEAT-blog-to-review-migration).
// Generates one static redirect page per post slug so EVERY old review URL keeps
// returning 200 and never 404s. The real read page now lives at /review/[slug].
import RedirectStub from '@components/redirect-stub.astro'
import { getCollection } from 'astro:content'

export const prerender = true

export async function getStaticPaths() {
	const entries = await getCollection('blog')
	return entries.map(e => ({
		params: { slug: e.data.slug },
		props: { slug: e.data.slug },
	}))
}

const { slug } = Astro.props as { slug: string }
---
<RedirectStub to={`/review/${slug}/`} />
