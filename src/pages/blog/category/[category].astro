---
// Legacy /blog/category/[category] → /reviews/ redirect stub (FEAT-blog-to-review-migration).
// Per-category pages are removed (folded into the /reviews browser). Keep the same
// getStaticPaths enumeration so every old category URL keeps a 200 stub and never 404s.
import RedirectStub from '@components/redirect-stub.astro'
import { getCollection } from 'astro:content'

export const prerender = true

export async function getStaticPaths() {
	const entries = await getCollection('blog')
	const cats = new Set(entries.filter(e => !e.data.draft).map(e => e.data.category))
	return Array.from(cats).map(category => ({ params: { category } }))
}
---
<RedirectStub to="/reviews/" />
