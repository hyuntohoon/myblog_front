---
import Layout from '@layouts/layout.astro'
import Seo from '@components/seo.astro'
import SkipNavContent from '@components/a11y/skip-nav-content.astro'
import ReviewsIndex from '@components/reviews/ReviewsIndex'
import { getCollection } from 'astro:content'
import { buildReviewCards } from '@lib/reviews'
import '@styles/reviews.css'

// /reviews — editorial "design C" layout: an oversized featured hero over a
// 3-column big-cover grid, with the same interactive filters/sort/search.
const reviews = buildReviewCards(await getCollection('blog'))
---

<Layout>
  <Seo slot="seo" title="리뷰 — RAMAMU" description="정성껏 들은 앨범들에 대한 기록." />

  <SkipNavContent>
    <div class="container">
      <!-- Masthead -->
      <header class="rev-masthead">
        <p class="rev-kicker">RAMAMU Music Reviews</p>
        <h1 class="rev-title">Reviews</h1>
        <p class="rev-sub">큰 커버로 읽는 전체 평론.</p>
      </header>

      {reviews.length === 0 ?
(
        <div class="rev-empty">
          <p class="rev-empty-title">아직 리뷰가 없습니다</p>
          <p class="rev-empty-sub">첫 리뷰를 작성해 보세요.</p>
        </div>
      ) :
(
        <ReviewsIndex client:load reviews={reviews} variant="editorial" />
      )}

      <!-- Footer -->
      <footer class="rev-footer">
        <span>RAMAMU — 음악 비평</span>
      </footer>
    </div>
  </SkipNavContent>
</Layout>
