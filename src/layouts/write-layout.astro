---
import { Font } from 'astro:assets'
import ThemeProvider from '@components/theme-provider.astro'

import '../styles/global.css'
// The ⌘K CommandPalette renders shared search atoms (ResultRow / .gs-*), whose
// styles live in search.css — incl. .gs-cover img { width/height: 100% }. Without
// this import the writer palette's covers render at full natural size (the artist
// drill-in photo fills the panel) and the rows lose their flex layout. The global
// /search, the header dropdown, and the member bucket modal already pull search.css in.
import '../styles/search.css'
import '../styles/writer.css'
import '../styles/research.css'
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <Font cssVariable="--font-plex-sans" preload />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
	href="https://fonts.googleapis.com/css2?family=Newsreader:ital,opsz,wght@0,6..72,400;0,6..72,500;0,6..72,600;0,6..72,700;1,6..72,400;1,6..72,500;1,6..72,600&family=Noto+Serif+KR:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500&display=swap"
	rel="stylesheet"
    />
    <ThemeProvider />
    <slot name="seo" />
  </head>
  <body>
    <slot />
  </body>
</html>
