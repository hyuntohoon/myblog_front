---
import { Font } from 'astro:assets'
import { ClientRouter } from 'astro:transitions'
import { SITE } from '@constants'
import SkipNavLink from '@components/a11y/skip-nav-link.astro'
import Header from '@components/header.astro'
import Footer from '@components/footer.astro'
import ThemeProvider from '@components/theme-provider.astro'
import IosInstallHint from '@components/ios-install-hint.astro'
import PocketBuckit from '@components/member/pocket/PocketBuckit'
import AlbumOverlay from '@components/album/AlbumOverlay'
import { pwaInfo } from 'virtual:pwa-info'

import '../styles/global.css'
// The header search island (FEAT-global-search) renders site-wide; its dropdown
// styles live in search.css. Importing here (not just on /search) styles the
// header field + dropdown on every page.
import '../styles/search.css';
---

<!doctype html>
<html lang={SITE.lang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="alternate" type="application/rss+xml" title="buckit" href="/rss.xml" />
		<!--
			FEAT-mobile-web-app Step 4 — PWA chrome. theme-color matches the dark
			--color-bg (manifest theme_color ditto); apple-touch-icon + the
			web-app-capable meta cover iOS, which ignores most of the manifest.
		-->
		<meta name="theme-color" content="#141312" />
		<link rel="apple-touch-icon" href="/pwa-192x192.png" />
		<meta name="mobile-web-app-capable" content="yes" />
		<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
		<meta name="apple-mobile-web-app-title" content="buckit" />
		{pwaInfo && <Fragment set:html={pwaInfo.webManifest.linkTag} />}
		<script src="../pwa.ts"></script>
		<meta name="generator" content={Astro.generator} />
		<Font cssVariable="--font-plex-sans" preload />
		<!-- Editorial font stack: Newsreader (display serif) + Noto Serif KR + IBM Plex Mono -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Newsreader:ital,opsz,wght@0,6..72,400;0,6..72,500;0,6..72,600;0,6..72,700;1,6..72,400;1,6..72,500;1,6..72,600&family=Noto+Serif+KR:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet" />
		<ThemeProvider />
		<!--
			FEAT-mobile-web-app Step 3: SPA-style navigation with cross-page fade.
			Unsupported browsers fall back to normal MPA loads (the router still
			fires astro:page-load, which page scripts now key off).
		-->
		<ClientRouter />
		<slot name="seo" />
	</head>
	<body class="min-h-screen bg-bg text-text">
		<SkipNavLink />
		<Header />
		<slot />
		<Footer />
		<!--
			transition:persist keeps this island's React state (tray contents,
			open drawers) across ClientRouter navigations.
		-->
		<PocketBuckit client:only="react" transition:persist="pocket-buckit" />
		<!--
			ARCH-entity-interaction-unify Step 1 — app-wide read-only album overlay.
			Un-gated (works on public pages, unlike PocketBuckit); opened by the
			`ent:open-album` event any surface dispatches via openAlbum().
		-->
		<AlbumOverlay client:only="react" transition:persist="album-overlay" />
		<IosInstallHint />
	</body>
</html>
